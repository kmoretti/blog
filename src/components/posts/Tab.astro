---
interface Props {
  /** 标签页名称数组 */
  tabs: string[];
  /** 初始激活的标签（从 1 开始） */
  active?: number;
  /** 是否居中 */
  center?: boolean;
}

const { tabs, active = 1, center = false } = Astro.props;

// 唯一 ID 避免多实例冲突
const uid = `tab-${Math.random().toString(36).slice(2, 8)}`;
const wrapperClass = ["tab-wrapper", center && "tab-center"]
  .filter(Boolean)
  .join(" ");
---

<div class={wrapperClass} data-tab-group={uid} data-active={active}>
  <div class="tabs" role="tablist">
    {
      tabs.map((tab, i) => (
        <button
          role="tab"
          class:list={[{ active: active === i + 1 }]}
          data-tab-index={i + 1}
          aria-selected={active === i + 1}
        >
          {tab}
        </button>
      ))
    }
  </div>
  <div
    class="tab-content"
    role="tabpanel"
    data-tab-index="1"
    style={active !== 1 ? "display: none" : ""}
  >
    <slot name="tab1" />
  </div>
  <div
    class="tab-content"
    role="tabpanel"
    data-tab-index="2"
    style={active !== 2 ? "display: none" : ""}
  >
    <slot name="tab2" />
  </div>
  <div
    class="tab-content"
    role="tabpanel"
    data-tab-index="3"
    style={active !== 3 ? "display: none" : ""}
  >
    <slot name="tab3" />
  </div>
  <div
    class="tab-content"
    role="tabpanel"
    data-tab-index="4"
    style={active !== 4 ? "display: none" : ""}
  >
    <slot name="tab4" />
  </div>
  <div
    class="tab-content"
    role="tabpanel"
    data-tab-index="5"
    style={active !== 5 ? "display: none" : ""}
  >
    <slot name="tab5" />
  </div>
  <div
    class="tab-content"
    role="tabpanel"
    data-tab-index="6"
    style={active !== 6 ? "display: none" : ""}
  >
    <slot name="tab6" />
  </div>
</div>

<script is:inline>
  function initTabs(root) {
    const buttons = root.querySelectorAll("[role='tab']");
    const panels = root.querySelectorAll("[role='tabpanel']");

    function switchTab(index) {
      buttons.forEach((btn, i) => {
        const isActive = i + 1 === index;
        btn.classList.toggle("active", isActive);
        btn.setAttribute("aria-selected", isActive);
      });
      panels.forEach((panel, i) => {
        panel.style.display = i + 1 === index ? "" : "none";
      });
      root.dataset.active = index;
    }

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        switchTab(Number(btn.dataset.tabIndex));
      });
    });
  }

  // 初始页面加载
  document.querySelectorAll("[data-tab-group]").forEach(initTabs);

  // View Transitions 兼容
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll("[data-tab-group]").forEach(initTabs);
  });
</script>

<style>
  .tab-wrapper {
    margin: 1.5em 0;
  }

  .tab-center {
    width: fit-content;
    max-width: 100%;
    margin-inline: auto;
  }

  .tabs {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5em;
    position: relative;
    width: fit-content;
    margin: 0 auto;
    font-size: 0.9em;
    line-height: 1.4;
  }

  .tabs button {
    position: relative;
    margin-bottom: 0.5em;
    padding: 0.3em 0.5em;
    border: none;
    border-radius: 0.4em;
    background: transparent;
    color: var(--fp-muted);
    cursor: pointer;
    font: inherit;
    transition: all 0.2s;
  }

  .tabs button:hover {
    background-color: var(--fp-warm);
    color: var(--fp-ink);
  }

  .tabs button::before,
  .tabs button::after {
    display: block;
    position: absolute;
    left: 0.8em;
    right: 0.8em;
    bottom: -0.5em;
    height: 2px;
    border-radius: 1em;
    pointer-events: none;
    content: "";
  }

  .tabs button::after {
    left: -0.8em;
    right: -0.8em;
    background-color: var(--fp-dash);
  }

  .tabs button.active {
    box-shadow:
      0 1px 2px color-mix(in srgb, var(--fp-ink) 6%, transparent),
      0 1px 3px color-mix(in srgb, var(--fp-ink) 10%, transparent);
    background-color: var(--fp-paper);
    color: var(--fp-ink);
  }

  .tabs button.active::before {
    background-color: var(--fp-accent);
    z-index: 1;
  }

  .tab-content {
    margin: 1em 0;
  }
</style>
