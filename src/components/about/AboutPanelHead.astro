---
interface Props {
  kicker: string;
  title: string;
}

const { kicker, title } = Astro.props;
---

<div class="panel-head">
  <span>{kicker}</span>
  <h2>{title}</h2>
</div>

<style>
  .panel-head {
    display: grid;
    gap: 0.3rem;
    margin-bottom: 0.95rem;
  }

  .panel-head span {
    color: var(--about-accent-strong, rgb(37 99 235 / 0.85));
    font-family: "Noto Sans Mono", monospace;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .panel-head h2 {
    margin: 0;
    color: rgb(24 24 27);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    font-weight: 800;
    line-height: 1.2;
  }

  :global(html.dark) .panel-head span {
    color: var(--about-accent-strong, rgb(96 165 250 / 0.9));
  }

  :global(html.dark) .panel-head h2 {
    color: rgb(244 244 245);
  }
</style>
