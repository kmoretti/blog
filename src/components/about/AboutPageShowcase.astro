---
import { Icon } from "astro-icon/components";
import { ABOUT_PAGE } from "../../consts";
import AboutPanelHead from "./AboutPanelHead.astro";

//import dockerIcon from "../../../关于 _ LiuShen's Blog - 清羽飞扬_files/63300647df7fa.png";
//import cssIcon from "../../../关于 _ LiuShen's Blog - 清羽飞扬_files/633006cc55e07.png";
//import javascriptIcon from "../../../关于 _ LiuShen's Blog - 清羽飞扬_files/633006eee047b.png";
//import htmlIcon from "../../../关于 _ LiuShen's Blog - 清羽飞扬_files/633006f9ab27d.png";

const about = ABOUT_PAGE;
const avatarUrl = "/avatar.jpeg";
//const skillIcons = {
//  html: htmlIcon,
//  css: cssIcon,
//  javascript: javascriptIcon,
//  docker: dockerIcon,
//} as const;

const getSkillImage = (_key: string) => undefined;
const featuredSkills = about.skills.featured.map((skill) => ({
  ...skill,
  image: getSkillImage(skill.key),
}));
---

<section class="about-page">
  <nav aria-label="Breadcrumb" class="about-breadcrumb">
    <a href="/">首页</a>
    <span>/</span>
    <strong>{about.title}</strong>
  </nav>

  <section class="about-hero">
    <div class="aurora aurora-1"></div>
    <div class="aurora aurora-2"></div>
    <div class="aurora aurora-3"></div>

    <div class="hero-content">
      <div class="float-cloud float-cloud-left" aria-hidden="true">
        {
          about.hero.floatingTagsLeft.map((item, index) => (
            <span class={`float-pill float-pill-${index + 1}`}>{item}</span>
          ))
        }
      </div>

      <div class="hero-center">
        <span class="hero-eyebrow">{about.hero.eyebrow}</span>
        <div class="avatar-ring">
          <div class="avatar-inner">
            <img
              src={avatarUrl}
              alt={`${about.hero.name} 的头像`}
              class="hero-avatar"
            />
          </div>
        </div>
        <p class="hero-greeting">{about.hero.greeting}</p>
        <h1>{about.hero.name}</h1>
        <p class="hero-motto">{about.hero.motto}</p>
        <p class="hero-summary">{about.hero.summary}</p>
      </div>

      <div class="float-cloud float-cloud-right" aria-hidden="true">
        {
          about.hero.floatingTagsRight.map((item, index) => (
            <span class={`float-pill float-pill-${index + 5}`}>{item}</span>
          ))
        }
      </div>
    </div>
  </section>

  <section class="about-card-grid">
    <section class="about-card about-card-profile">
      <AboutPanelHead
        kicker={about.profile.kicker}
        title={about.profile.title}
      />
      {about.profile.intro && <p class="card-copy">{about.profile.intro}</p>}
      <div class="info-list">
        {
          about.profile.infoItems.map((item) => (
            <div class="info-item">
              <span class="info-label">{item.label}</span>
              {item.href ? (
                <a
                  class="info-value"
                  href={item.href}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {item.value}
                </a>
              ) : (
                <span class="info-value">{item.value}</span>
              )}
            </div>
          ))
        }
      </div>
    </section>

    <section class="about-card about-card-writing">
      <AboutPanelHead
        kicker={about.writing.kicker}
        title={about.writing.title}
      />
      <p class="writing-heading">{about.writing.heading}</p>
      <p class="card-copy">{about.writing.summary}</p>
      <div class="trait-list">
        {about.writing.traits.map((trait) => <span>{trait}</span>)}
      </div>
      <a class="text-link" href={about.writing.cta.href}>
        {about.writing.cta.label}
      </a>
    </section>

    <section class="about-card about-card-skills">
      <AboutPanelHead kicker={about.skills.kicker} title={about.skills.title} />
      <div class="featured-skills">
        {
          featuredSkills.map((skill, index) => (
            <figure class="featured-skill" style={`--delay:${index * 0.04}s`}>
              <span class="featured-skill-icon" aria-hidden="true">
                {skill.icon ? (
                  <Icon name={skill.icon} width="48" height="48" />
                ) : skill.image ? (
                  <img
                    src={skill.image}
                    alt=""
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <span class="featured-skill-fallback">
                    {skill.label.slice(0, 1)}
                  </span>
                )}
              </span>
              <figcaption>{skill.label}</figcaption>
            </figure>
          ))
        }
      </div>
      <div class="skill-tags">
        {about.skills.tags.map((tag) => <span>{tag}</span>)}
      </div>
      <p class="muted-note">{about.skills.note}</p>
    </section>

    <section class="about-card about-card-contact">
      <AboutPanelHead
        kicker={about.contact.kicker}
        title={about.contact.title}
      />
      <div class="social-grid">
        {
          about.contact.links.map((link) => (
            <a
              class="social-card"
              href={link.href}
              target={link.href.startsWith("mailto:") ? undefined : "_blank"}
              rel={
                link.href.startsWith("mailto:")
                  ? undefined
                  : "noopener noreferrer"
              }
            >
              <span class="social-badge" aria-hidden="true">
                {link.badge}
              </span>
              <span class="social-copy">
                <strong>{link.label}</strong>
                <small>{link.note}</small>
              </span>
            </a>
          ))
        }
      </div>
      <div class="trait-list hobby-list">
        {about.contact.hobbies.map((hobby) => <span>{hobby}</span>)}
      </div>
    </section>

    <section class="about-card about-card-projects">
      <AboutPanelHead
        kicker={about.projects.kicker}
        title={about.projects.title}
      />
      <div class="project-list">
        {
          about.projects.items.map((item) =>
            item.href ? (
              <a
                class="project-item"
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="project-kicker">Project</span>
                <strong>{item.title}</strong>
                <p>{item.description}</p>
              </a>
            ) : (
              <div class="project-item">
                <span class="project-kicker">Project</span>
                <strong>{item.title}</strong>
                <p>{item.description}</p>
              </div>
            ),
          )
        }
      </div>
      <div class="project-focus">
        <span>{about.projects.focusTitle}</span>
        <div class="project-focus-grid">
          {
            about.projects.focus.map((item) => (
              <div class="project-focus-item">
                <strong>{item.title}</strong>
                <p>{item.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="about-card about-card-evaluation">
      <AboutPanelHead
        kicker={about.evaluation.kicker}
        title={about.evaluation.title}
      />
      <div class="evaluation-list">
        {
          about.evaluation.items.map((item) => (
            <div>
              <span>{item.label}</span>
              <p>{item.description}</p>
            </div>
          ))
        }
      </div>
    </section>
  </section>

  <section class="about-card about-card-comments" id="comment-section">
    <AboutPanelHead
      kicker={about.comments.kicker}
      title={about.comments.title}
    />
    <p class="card-copy">{about.comments.description}</p>
    <div class="comment-shell">
      <slot />
    </div>
  </section>
</section>

<style>
  .about-page {
    --about-accent: #ecd452;
    --about-accent-rgb: 236 212 82;
    --about-accent-strong: #b9971d;
    --about-accent-contrast: rgb(39 39 42);
    --about-accent-surface: rgb(var(--about-accent-rgb) / 0.12);
    --about-accent-border: rgb(var(--about-accent-rgb) / 0.24);
    --about-accent-glow: rgb(var(--about-accent-rgb) / 0.2);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-bottom: 4rem;
  }

  .about-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    color: rgb(113 113 122);
    font-size: 0.92rem;
  }

  .about-breadcrumb a {
    color: inherit;
    text-decoration: none;
  }

  .about-breadcrumb a:hover {
    text-decoration: underline;
  }

  .about-breadcrumb strong {
    color: rgb(39 39 42);
    font-weight: 600;
  }

  .about-hero {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--about-accent-border);
    border-radius: 1.6rem;
    background:
      radial-gradient(
        circle at top left,
        rgb(var(--about-accent-rgb) / 0.18),
        transparent 22rem
      ),
      radial-gradient(
        circle at bottom right,
        rgb(24 24 27 / 0.05),
        transparent 24rem
      ),
      linear-gradient(180deg, rgb(252 251 246), rgb(247 246 240));
    box-shadow:
      0 20px 48px -34px var(--about-accent-glow),
      inset 0 1px rgb(255 255 255 / 0.7);
    padding: 2.75rem 1.85rem;
  }

  .aurora {
    position: absolute;
    border-radius: 999px;
    filter: blur(60px);
    opacity: 0.9;
    pointer-events: none;
  }

  .aurora-1 {
    inset: -7rem auto auto -5rem;
    width: 18rem;
    height: 18rem;
    background: rgb(var(--about-accent-rgb) / 0.24);
  }

  .aurora-2 {
    inset: auto -4rem 0 auto;
    width: 14rem;
    height: 14rem;
    background: rgb(var(--about-accent-rgb) / 0.14);
  }

  .aurora-3 {
    inset: 35% 50% auto auto;
    width: 10rem;
    height: 10rem;
    background: rgb(24 24 27 / 0.08);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: 1rem;
    padding-inline: 0.35rem;
  }

  .hero-center {
    display: flex;
    max-width: 30rem;
    flex-direction: column;
    align-items: center;
    margin: 0 auto;
    text-align: center;
  }

  .hero-eyebrow {
    color: var(--about-accent-strong);
    font-family: "Noto Sans Mono", monospace;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .avatar-ring {
    width: 7rem;
    height: 7rem;
    margin: 0.85rem 0 1rem;
    padding: 0.28rem;
    border-radius: 999px;
    background: rgb(var(--about-accent-rgb) / 0.42);
    box-shadow: 0 18px 42px -30px rgb(var(--about-accent-rgb) / 0.45);
  }

  .avatar-inner {
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: inherit;
    background: rgb(255 255 255);
  }

  .hero-avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-greeting {
    margin: 0;
    color: rgb(82 82 91);
    font-size: 0.98rem;
  }

  .hero-center h1 {
    margin: 0.15rem 0 0;
    color: rgb(24 24 27);
    font-size: clamp(1.8rem, 5vw, 2.65rem);
    font-weight: 900;
    line-height: 1.08;
  }

  .hero-motto {
    margin: 0.8rem 0 0;
    color: rgb(39 39 42);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.7;
  }

  .hero-summary {
    max-width: 32rem;
    margin: 0.65rem 0 0;
    color: rgb(82 82 91);
    line-height: 1.8;
  }

  .float-cloud {
    display: flex;
    flex-direction: column;
    gap: 0.62rem;
    width: fit-content;
  }

  .float-cloud-left {
    justify-self: start;
    align-items: flex-end;
    padding-left: 0.35rem;
  }

  .float-cloud-right {
    justify-self: end;
    align-items: flex-start;
    padding-right: 0.35rem;
  }

  .float-pill {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.2rem 0.95rem;
    border: 1px solid rgb(148 163 184 / 0.28);
    border-radius: 999px;
    background: rgb(255 255 255 / 0.65);
    box-shadow: inset 0 1px rgb(255 255 255 / 0.8);
    color: rgb(39 39 42 / 0.86);
    font-size: 0.84rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .float-pill-2,
  .float-pill-3 {
    margin-right: 1.2rem;
  }

  .float-pill-6,
  .float-pill-7 {
    margin-left: 1.2rem;
  }

  .about-card-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1rem;
  }

  .about-card {
    overflow: hidden;
    border: 1px solid rgb(228 228 231);
    border-radius: 1.2rem;
    background: linear-gradient(
      180deg,
      rgb(255 255 255 / 0.96),
      rgb(250 250 250 / 0.94)
    );
    box-shadow:
      0 18px 42px -36px rgb(24 24 27 / 0.28),
      inset 0 1px rgb(255 255 255 / 0.75);
    padding: 1.15rem;
  }

  .about-card-profile,
  .about-card-projects {
    grid-column: span 7;
  }

  .about-card-writing,
  .about-card-evaluation {
    grid-column: span 5;
  }

  .about-card-skills {
    grid-column: span 8;
  }

  .about-card-contact {
    grid-column: span 4;
  }

  .about-card-comments {
    margin-top: 0.15rem;
  }

  .card-copy {
    margin: 0;
    color: rgb(82 82 91);
    line-height: 1.8;
  }

  .info-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
    gap: 0.7rem;
    margin-top: 1rem;
  }

  .info-item,
  .featured-skill,
  .social-card,
  .project-item,
  .project-focus-item,
  .evaluation-list > div {
    border: 1px solid rgb(228 228 231 / 0.9);
    border-radius: 0.95rem;
    background: rgb(255 255 255 / 0.72);
    box-shadow: inset 0 1px rgb(255 255 255 / 0.8);
  }

  .info-item {
    display: flex;
    min-height: 3.35rem;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.72rem 0.82rem;
  }

  .info-label {
    color: rgb(113 113 122);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.05em;
  }

  .info-value {
    color: rgb(24 24 27);
    font-size: 0.9rem;
    font-weight: 700;
    text-align: right;
    text-decoration: none;
    overflow-wrap: anywhere;
  }

  a.info-value:hover,
  .text-link:hover {
    color: var(--about-accent-strong);
  }

  .writing-heading {
    margin: 0;
    color: rgb(24 24 27);
    font-size: 1.2rem;
    font-weight: 800;
    line-height: 1.5;
  }

  .trait-list,
  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1rem;
  }

  .trait-list span,
  .skill-tags span {
    display: inline-flex;
    align-items: center;
    min-height: 1.95rem;
    padding: 0.28rem 0.72rem;
    border: 1px solid var(--about-accent-border);
    border-radius: 999px;
    background: var(--about-accent-surface);
    color: rgb(39 39 42 / 0.9);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .text-link {
    display: inline-flex;
    margin-top: 1rem;
    color: var(--about-accent-strong);
    font-size: 0.92rem;
    font-weight: 700;
    text-decoration: none;
  }

  .featured-skills {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .featured-skill {
    display: grid;
    gap: 0.55rem;
    justify-items: center;
    padding: 0.85rem 0.7rem;
    text-align: center;
    animation: skill-enter 0.45s ease both;
    animation-delay: var(--delay);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease;
  }

  .featured-skill:hover,
  .social-card:hover,
  .project-item:hover {
    border-color: rgb(var(--about-accent-rgb) / 0.4);
    transform: translateY(-2px);
  }

  .featured-skill-icon {
    display: grid;
    width: 3rem;
    height: 3rem;
    place-items: center;
  }

  .featured-skill-icon img,
  .featured-skill-icon :global(svg) {
    width: 3rem;
    height: 3rem;
    object-fit: contain;
  }

  .featured-skill-fallback {
    display: grid;
    width: 100%;
    height: 100%;
    place-items: center;
    border-radius: 0.85rem;
    background: var(--about-accent-surface);
    color: var(--about-accent-strong);
    font-size: 1rem;
    font-weight: 800;
  }

  .featured-skill figcaption {
    color: rgb(39 39 42);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .muted-note {
    margin: 0.95rem 0 0;
    color: rgb(113 113 122);
    font-size: 0.9rem;
  }

  .social-grid {
    display: grid;
    gap: 0.65rem;
  }

  .social-card {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.75rem;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease;
  }

  .social-badge {
    display: grid;
    width: 2.45rem;
    height: 2.45rem;
    place-items: center;
    border-radius: 0.8rem;
    background: var(--about-accent);
    color: var(--about-accent-contrast);
    font-size: 0.86rem;
    font-weight: 800;
    flex-shrink: 0;
  }

  .social-copy {
    display: grid;
    gap: 0.12rem;
    min-width: 0;
  }

  .social-copy strong {
    color: rgb(24 24 27);
    font-size: 0.92rem;
  }

  .social-copy small {
    color: rgb(113 113 122);
    font-size: 0.8rem;
    line-height: 1.55;
  }

  .hobby-list {
    margin-top: 0.95rem;
  }

  .project-list,
  .project-focus-grid {
    display: grid;
    gap: 0.7rem;
  }

  .project-list {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .project-item {
    display: grid;
    gap: 0.35rem;
    min-height: 7rem;
    padding: 0.9rem;
    color: inherit;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease;
  }

  .project-kicker,
  .project-focus > span {
    color: var(--about-accent-strong);
    font-family: "Noto Sans Mono", monospace;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .project-item strong,
  .project-focus-item strong {
    color: rgb(24 24 27);
    font-size: 0.98rem;
  }

  .project-item p,
  .project-focus-item p,
  .evaluation-list p {
    margin: 0;
    color: rgb(82 82 91);
    font-size: 0.88rem;
    line-height: 1.72;
  }

  .project-focus {
    display: grid;
    gap: 0.7rem;
    margin-top: 0.9rem;
  }

  .project-focus-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .project-focus-item,
  .evaluation-list > div {
    padding: 0.8rem 0.85rem;
  }

  .evaluation-list {
    display: grid;
    gap: 0.65rem;
  }

  .evaluation-list span {
    display: inline-block;
    margin-bottom: 0.3rem;
    color: var(--about-accent-strong);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.05em;
  }

  :global(html.dark) .about-page {
    --about-accent: #b1d5c8;
    --about-accent-rgb: 177 213 200;
    --about-accent-strong: #b1d5c8;
    --about-accent-contrast: rgb(24 24 27);
    --about-accent-surface: rgb(var(--about-accent-rgb) / 0.12);
    --about-accent-border: rgb(var(--about-accent-rgb) / 0.24);
    --about-accent-glow: rgb(var(--about-accent-rgb) / 0.22);
  }

  .comment-shell {
    margin-top: 0.25rem;
  }

  .comment-shell :global(.giscus-container) {
    margin-top: 1rem;
  }

  .comment-shell :global(.giscus-hint) {
    margin-bottom: 1rem;
  }

  :global(html.dark) .about-breadcrumb,
  :global(html.dark) .card-copy,
  :global(html.dark) .hero-summary,
  :global(html.dark) .hero-greeting,
  :global(html.dark) .muted-note,
  :global(html.dark) .social-copy small,
  :global(html.dark) .project-item p,
  :global(html.dark) .project-focus-item p,
  :global(html.dark) .evaluation-list p {
    color: rgb(161 161 170);
  }

  :global(html.dark) .about-breadcrumb strong,
  :global(html.dark) .writing-heading,
  :global(html.dark) .info-value,
  :global(html.dark) .featured-skill figcaption,
  :global(html.dark) .social-copy strong,
  :global(html.dark) .project-item strong,
  :global(html.dark) .project-focus-item strong,
  :global(html.dark) .hero-motto {
    color: rgb(244 244 245);
  }

  :global(html.dark) .about-hero {
    border-color: var(--about-accent-border);
    background:
      radial-gradient(
        circle at top left,
        rgb(var(--about-accent-rgb) / 0.18),
        transparent 22rem
      ),
      radial-gradient(
        circle at bottom right,
        rgb(255 255 255 / 0.05),
        transparent 22rem
      ),
      linear-gradient(180deg, rgb(42 44 43), rgb(24 24 27));
    box-shadow:
      0 24px 50px -36px var(--about-accent-glow),
      inset 0 1px rgb(255 255 255 / 0.05);
  }

  :global(html.dark) .avatar-inner,
  :global(html.dark) .about-card,
  :global(html.dark) .info-item,
  :global(html.dark) .featured-skill,
  :global(html.dark) .social-card,
  :global(html.dark) .project-item,
  :global(html.dark) .project-focus-item,
  :global(html.dark) .evaluation-list > div {
    border-color: rgb(63 63 70);
