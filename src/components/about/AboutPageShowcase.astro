---
import { Icon } from "astro-icon/components";
import { ABOUT_PAGE } from "../../consts";
import AboutPanelHead from "./AboutPanelHead.astro";

const about = ABOUT_PAGE;
const avatarUrl = "https://q2.qlogo.cn/headimg_dl?dst_uin=3149261770&spec=0";

const getSkillImage = (_key: string) => undefined;
const featuredSkills = about.skills.featured.map((skill) => ({
  ...skill,
  image: getSkillImage(skill.key),
}));
---

<section class="about-page">
  <nav aria-label="Breadcrumb" class="about-breadcrumb">
    <a href="/">首页</a>
    <span>/</span>
    <strong>{about.title}</strong>
  </nav>

  <section class="about-hero">
    <span class="about-hero-tape" aria-hidden="true"></span>

    <div class="hero-content">
      <div class="float-cloud float-cloud-left" aria-hidden="true">
        {
          about.hero.floatingTagsLeft.map((item, index) => (
            <span class={`float-pill float-pill-${index + 1}`}>{item}</span>
          ))
        }
      </div>

      <div class="hero-center">
        <span class="hero-eyebrow">{about.hero.eyebrow}</span>
        <div class="avatar-ring">
          <div class="avatar-inner">
            <img
              src={avatarUrl}
              alt={`${about.hero.name} 的头像`}
              class="hero-avatar"
            />
          </div>
        </div>
        <p class="hero-greeting">{about.hero.greeting}</p>
        <h1>{about.hero.name}</h1>
        <p class="hero-motto">{about.hero.motto}</p>
        <p class="hero-summary">{about.hero.summary}</p>
      </div>

      <div class="float-cloud float-cloud-right" aria-hidden="true">
        {
          about.hero.floatingTagsRight.map((item, index) => (
            <span class={`float-pill float-pill-${index + 5}`}>{item}</span>
          ))
        }
      </div>
    </div>
  </section>

  <section class="about-card-grid">
    <section class="about-card about-card-profile">
      <span class="fp-card-tape" aria-hidden="true"></span>
      <span class="fp-card-tab" aria-hidden="true"></span>
      <AboutPanelHead
        kicker={about.profile.kicker}
        title={about.profile.title}
      />
      {about.profile.intro && <p class="card-copy">{about.profile.intro}</p>}
      <div class="info-list">
        {
          about.profile.infoItems.map((item) => (
            <div class="info-item">
              <span class="info-label">{item.label}</span>
              {item.href ? (
                <a
                  class="info-value"
                  href={item.href}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {item.value}
                </a>
              ) : (
                <span class="info-value">{item.value}</span>
              )}
            </div>
          ))
        }
      </div>
    </section>

    <section class="about-card about-card-writing">
      <span class="fp-card-tape" aria-hidden="true"></span>
      <span class="fp-card-tab" aria-hidden="true"></span>
      <AboutPanelHead
        kicker={about.writing.kicker}
        title={about.writing.title}
      />
      <p class="writing-heading">{about.writing.heading}</p>
      <p class="card-copy">{about.writing.summary}</p>
      <div class="trait-list">
        {about.writing.traits.map((trait) => <span>{trait}</span>)}
      </div>
      <a class="text-link" href={about.writing.cta.href}>
        {about.writing.cta.label}
      </a>
    </section>

    <section class="about-card about-card-skills">
      <span class="fp-card-tape" aria-hidden="true"></span>
      <span class="fp-card-tab" aria-hidden="true"></span>
      <AboutPanelHead kicker={about.skills.kicker} title={about.skills.title} />
      <div class="featured-skills">
        {
          featuredSkills.map((skill, index) => (
            <figure class="featured-skill" style={`--delay:${index * 0.04}s`}>
              <span class="featured-skill-icon" aria-hidden="true">
                {skill.icon ? (
                  <Icon name={skill.icon} width="48" height="48" />
                ) : skill.image ? (
                  <img
                    src={skill.image}
                    alt=""
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <span class="featured-skill-fallback">
                    {skill.label.slice(0, 1)}
                  </span>
                )}
              </span>
              <figcaption>{skill.label}</figcaption>
            </figure>
          ))
        }
      </div>
      <div class="skill-tags">
        {about.skills.tags.map((tag) => <span>{tag}</span>)}
      </div>
      <p class="muted-note">{about.skills.note}</p>
    </section>

    <section class="about-card about-card-contact">
      <span class="fp-card-tape" aria-hidden="true"></span>
      <span class="fp-card-tab" aria-hidden="true"></span>
      <AboutPanelHead
        kicker={about.contact.kicker}
        title={about.contact.title}
      />
      <div class="social-grid">
        {
          about.contact.links.map((link) => (
            <a
              class="social-card"
              href={link.href}
              target={link.href.startsWith("mailto:") ? undefined : "_blank"}
              rel={
                link.href.startsWith("mailto:")
                  ? undefined
                  : "noopener noreferrer"
              }
            >
              <span class="social-badge" aria-hidden="true">
                {link.badge.includes(":") ? (
                  <Icon name={link.badge} width="20" height="20" />
                ) : (
                  link.badge
                )}
              </span>
              <span class="social-copy">
                <strong>{link.label}</strong>
                <small>{link.note}</small>
              </span>
            </a>
          ))
        }
      </div>
      <div class="trait-list hobby-list">
        {about.contact.hobbies.map((hobby) => <span>{hobby}</span>)}
      </div>
    </section>

    <section class="about-card about-card-projects">
      <span class="fp-card-tape" aria-hidden="true"></span>
      <span class="fp-card-tab" aria-hidden="true"></span>
      <AboutPanelHead
        kicker={about.projects.kicker}
        title={about.projects.title}
      />
      <div class="project-list">
        {
          about.projects.items.map((item) =>
            item.href ? (
              <a
                class="project-item"
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="project-kicker">Project</span>
                <strong>{item.title}</strong>
                <p>{item.description}</p>
              </a>
            ) : (
              <div class="project-item">
                <span class="project-kicker">Project</span>
                <strong>{item.title}</strong>
                <p>{item.description}</p>
              </div>
            ),
          )
        }
      </div>
      <div class="project-focus">
        <span>{about.projects.focusTitle}</span>
        <div class="project-focus-grid">
          {
            about.projects.focus.map((item) => (
              <div class="project-focus-item">
                <strong>{item.title}</strong>
                <p>{item.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="about-card about-card-evaluation">
      <span class="fp-card-tape" aria-hidden="true"></span>
      <span class="fp-card-tab" aria-hidden="true"></span>
      <AboutPanelHead
        kicker={about.evaluation.kicker}
        title={about.evaluation.title}
      />
      <div class="evaluation-list">
        {
          about.evaluation.items.map((item) => (
            <div>
              <span>{item.label}</span>
              <p>{item.description}</p>
            </div>
          ))
        }
      </div>
    </section>
  </section>

  <section class="about-card about-card-comments">
    <span class="fp-card-tape" aria-hidden="true"></span>
    <span class="fp-card-tab" aria-hidden="true"></span>
    <AboutPanelHead
      kicker={about.comments.kicker}
      title={about.comments.title}
    />
    <p class="card-copy">{about.comments.description}</p>
    <div class="comment-shell">
      <slot />
    </div>
  </section>
</section>

<style>
  .about-page {
    --ab-tape-0: var(--fp-tape);
    --ab-tape-1: rgba(240, 155, 192, 0.68);
    --ab-tape-2: rgba(134, 217, 147, 0.68);
    --ab-tape-3: rgba(135, 185, 232, 0.68);
    --ab-tape-4: rgba(245, 215, 66, 0.72);
    --ab-tape-5: rgba(200, 170, 230, 0.68);
    --ab-tab-0: #7cb87c;
    --ab-tab-1: #7cb87c;
    --ab-tab-2: #6ba8d6;
    --ab-tab-3: #f5d742;
    --ab-tab-4: #e8a0b8;
    --ab-tab-5: #b8a0d8;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-bottom: 4rem;
  }

  html.dark .about-page {
    --ab-tape-0: rgba(180, 150, 80, 0.5);
    --ab-tape-1: rgba(158, 95, 122, 0.56);
    --ab-tape-2: rgba(79, 122, 85, 0.56);
    --ab-tape-3: rgba(79, 111, 138, 0.56);
    --ab-tape-4: rgba(168, 134, 42, 0.56);
    --ab-tape-5: rgba(130, 100, 160, 0.56);
    --ab-tab-0: #4a7a4a;
    --ab-tab-1: #4a7a4a;
    --ab-tab-2: #3d6a8a;
    --ab-tab-3: #a8862a;
    --ab-tab-4: #8a5f70;
    --ab-tab-5: #7a5a8a;
  }

  .about-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--fp-muted);
    font-size: 0.92rem;
  }

  .about-breadcrumb a {
    color: inherit;
    text-decoration: none;
  }

  .about-breadcrumb a:hover {
    text-decoration: underline;
  }

  .about-breadcrumb strong {
    color: var(--fp-ink);
    font-weight: 600;
  }

  /* ── Hero ── */
  .about-hero {
    position: relative;
    overflow: hidden;
    border-radius: 255px 18px 225px 18px / 18px 225px 18px 255px;
    background: linear-gradient(
      165deg,
      var(--fp-paper) 0%,
      color-mix(in srgb, var(--fp-warm) 92%, var(--fp-accent-soft) 8%) 100%
    );
    box-shadow:
      var(--fp-small-shadow),
      inset 0 1px color-mix(in srgb, var(--fp-paper) 75%, transparent);
    border: 1px solid color-mix(in srgb, var(--fp-dash) 60%, transparent);
    padding: 2.75rem 1.85rem;
    transform: rotate(-0.15deg);
  }

  .about-hero-tape {
    position: absolute;
    top: -8px;
    left: 50%;
    z-index: 2;
    width: 52px;
    height: 18px;
    background-color: var(--ab-tape-0);
    background-image: repeating-linear-gradient(
      45deg,
      rgba(255, 255, 255, 0.25) 0 2px,
      transparent 2px 7px
    );
    transform: translateX(-50%) rotate(-2deg);
    border-radius: 2px;
    box-shadow: 0 3px 8px rgba(82, 64, 38, 0.12);
  }

  html.dark .about-hero-tape {
    background-image: repeating-linear-gradient(
      45deg,
      rgba(0, 0, 0, 0.15) 0 2px,
      transparent 2px 7px
    );
    box-shadow: 0 3px 8px rgba(0, 0, 0, 0.24);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: 1rem;
    padding-inline: 0.35rem;
  }

  .hero-center {
    display: flex;
    max-width: 30rem;
    flex-direction: column;
    align-items: center;
    margin: 0 auto;
    text-align: center;
  }

  .hero-eyebrow {
    color: var(--fp-accent-strong);
    font-family: "Noto Sans Mono", monospace;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .avatar-ring {
    width: 7rem;
    height: 7rem;
    margin: 0.85rem 0 1rem;
    padding: 0.28rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--fp-accent) 42%, transparent);
    box-shadow:
      0 18px 42px -30px color-mix(in srgb, var(--fp-accent) 45%, transparent),
      inset 0 1px color-mix(in srgb, var(--fp-paper) 80%, transparent);
  }

  .avatar-inner {
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: inherit;
    background: var(--fp-paper);
  }

  .hero-avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-greeting {
    margin: 0;
    color: var(--fp-ink-soft);
    font-size: 0.98rem;
  }

  .hero-center h1 {
    margin: 0.15rem 0 0;
    color: var(--fp-ink);
    font-size: clamp(1.8rem, 5vw, 2.65rem);
    font-weight: 900;
    line-height: 1.08;
  }

  .hero-motto {
    margin: 0.8rem 0 0;
    color: var(--fp-ink);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.7;
  }

  .hero-summary {
    max-width: 32rem;
    margin: 0.65rem 0 0;
    color: var(--fp-ink-soft);
    line-height: 1.8;
  }

  .float-cloud {
    display: flex;
    flex-direction: column;
    gap: 0.62rem;
    width: fit-content;
  }

  .float-cloud-left {
    justify-self: start;
    align-items: flex-end;
    padding-left: 0.35rem;
  }

  .float-cloud-right {
    justify-self: end;
    align-items: flex-start;
    padding-right: 0.35rem;
  }

  .float-pill {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.2rem 0.95rem;
    border-radius: 255px 8px 225px 8px / 8px 225px 8px 255px;
    background: color-mix(in srgb, var(--fp-paper) 72%, transparent);
    border: 1px solid color-mix(in srgb, var(--fp-dash) 70%, transparent);
    box-shadow:
      var(--fp-shadow),
      inset 0 1px color-mix(in srgb, var(--fp-paper) 80%, transparent);
    color: color-mix(in srgb, var(--fp-ink) 86%, transparent);
    font-size: 0.84rem;
    font-weight: 700;
    white-space: nowrap;
    transform: rotate(var(--fp-pill-rot, 0deg));
  }

  .float-pill-1 { --fp-pill-rot: -1.5deg; }
  .float-pill-2 { --fp-pill-rot: 0.8deg; margin-right: 1.2rem; }
  .float-pill-3 { --fp-pill-rot: -0.5deg; margin-right: 1.2rem; }
  .float-pill-4 { --fp-pill-rot: 1.2deg; }
  .float-pill-5 { --fp-pill-rot: -1deg; }
  .float-pill-6 { --fp-pill-rot: 0.6deg; margin-left: 1.2rem; }
  .float-pill-7 { --fp-pill-rot: -0.8deg; margin-left: 1.2rem; }
  .float-pill-8 { --fp-pill-rot: 1.5deg; }

  /* ── Card Grid ── */
  .about-card-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1rem;
  }

  .about-card {
    --ab-tilt: 0.12deg;
    position: relative;
    overflow: visible;
    border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;
    background: linear-gradient(
      160deg,
      var(--fp-paper) 0%,
      color-mix(in srgb, var(--fp-warm) 90%, transparent) 100%
    );
    border: 1px solid color-mix(in srgb, var(--fp-dash) 55%, transparent);
    box-shadow:
      var(--fp-shadow),
      inset 0 1px color-mix(in srgb, var(--fp-paper) 70%, transparent);
    padding: 1.15rem;
    transform: rotate(var(--ab-tilt));
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease;
  }

  .about-card:hover {
    transform: translateY(-2px) rotate(0deg);
    border-color: color-mix(in srgb, var(--fp-accent) 40%, var(--fp-dash));
    box-shadow:
      var(--fp-small-shadow),
      inset 0 1px color-mix(in srgb, var(--fp-paper) 70%, transparent);
  }

  .about-card-profile { --ab-tilt: -0.18deg; grid-column: span 7; }
  .about-card-writing { --ab-tilt: 0.22deg; grid-column: span 5; }
  .about-card-skills { --ab-tilt: -0.1deg; grid-column: span 8; }
  .about-card-contact { --ab-tilt: 0.25deg; grid-column: span 4; }
  .about-card-projects { --ab-tilt: -0.2deg; grid-column: span 7; }
  .about-card-evaluation { --ab-tilt: 0.15deg; grid-column: span 5; }
  .about-card-comments { --ab-tilt: -0.1deg; margin-top: 0.15rem; }

  /* ── Tape Decorations ── */
  .fp-card-tape {
    position: absolute;
    top: -7px;
    z-index: 2;
    width: 34px;
    height: 14px;
    background-color: var(--ab-tape-0);
    background-image: repeating-linear-gradient(
      45deg,
      rgba(255, 255, 255, 0.22) 0 2px,
      transparent 2px 6px
    );
    border-radius: 2px;
    box-shadow: 0 2px 6px rgba(82, 64, 38, 0.1);
    pointer-events: none;
  }

  html.dark .fp-card-tape {
    background-image: repeating-linear-gradient(
      45deg,
      rgba(0, 0, 0, 0.12) 0 2px,
      transparent 2px 6px
    );
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);
  }

  .about-card-profile .fp-card-tape {
    left: 28px;
    background-color: var(--ab-tape-1);
    transform: rotate(-4deg);
  }
  .about-card-writing .fp-card-tape {
    left: 20px;
    background-color: var(--ab-tape-2);
    transform: rotate(2deg);
  }
  .about-card-skills .fp-card-tape {
    left: 32px;
    background-color: var(--ab-tape-3);
    transform: rotate(-3deg);
  }
  .about-card-contact .fp-card-tape {
    left: 24px;
    background-color: var(--ab-tape-4);
    transform: rotate(3deg);
  }
  .about-card-projects .fp-card-tape {
    left: 30px;
    background-color: var(--ab-tape-5);
    transform: rotate(-2deg);
  }
  .about-card-evaluation .fp-card-tape {
    left: 22px;
    background-color: var(--ab-tape-1);
    transform: rotate(1.5deg);
  }
  .about-card-comments .fp-card-tape {
    left: 26px;
    background-color: var(--ab-tape-2);
    transform: rotate(-2.5deg);
  }

  /* ── Tab Decorations ── */
  .fp-card-tab {
    position: absolute;
    top: 18px;
    right: -5px;
    z-index: -1;
    width: 5px;
    height: 42px;
    border: 1px dashed color-mix(in srgb, var(--fp-dash) 50%, transparent);
    border-left: 0;
    border-radius: 0 6px 6px 0;
    background: var(--ab-tab-0);
    box-shadow: 2px 3px 0 rgba(82, 64, 38, 0.06);
    pointer-events: none;
    transition:
      width 0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
      right 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  html.dark .fp-card-tab {
    border-color: rgba(225, 230, 245, 0.08);
    box-shadow: 3px 3px 0 rgba(0, 0, 0, 0.14);
  }

  .about-card:hover .fp-card-tab {
    right: -10px;
    width: 10px;
  }

  .about-card-writing .fp-card-tab { background: var(--ab-tab-2); }
  .about-card-skills .fp-card-tab { background: var(--ab-tab-1); }
  .about-card-contact .fp-card-tab { background: var(--ab-tab-3); }
  .about-card-projects .fp-card-tab { background: var(--ab-tab-4); }
  .about-card-evaluation .fp-card-tab { background: var(--ab-tab-5); }
  .about-card-comments .fp-card-tab { background: var(--ab-tab-1); }

  /* ── Shared ── */
  .card-copy {
    margin: 0;
    color: var(--fp-ink-soft);
    line-height: 1.8;
  }

  .info-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
    gap: 0.7rem;
    margin-top: 1rem;
  }

  .info-item {
    display: flex;
    min-height: 3.35rem;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.72rem 0.82rem;
    border-radius: 255px 8px 225px 8px / 8px 225px 8px 255px;
    border: 1px solid color-mix(in srgb, var(--fp-dash) 55%, transparent);
    background: color-mix(in srgb, var(--fp-paper) 72%, transparent);
    box-shadow: inset 0 1px color-mix(in srgb, var(--fp-paper) 80%, transparent);
  }

  .info-label {
    color: var(--fp-muted);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.05em;
  }

  .info-value {
    color: var(--fp-ink);
    font-size: 0.9rem;
    font-weight: 700;
    text-align: right;
    text-decoration: none;
    overflow-wrap: anywhere;
  }

  a.info-value:hover,
  .text-link:hover {
    color: var(--fp-accent-strong);
  }

  .writing-heading {
    margin: 0;
    color: var(--fp-ink);
    font-size: 1.2rem;
    font-weight: 800;
    line-height: 1.5;
  }

  .trait-list,
  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1rem;
  }

  .trait-list span,
  .skill-tags span {
    display: inline-flex;
    align-items: center;
    min-height: 1.95rem;
    padding: 0.28rem 0.72rem;
    border-radius: 255px 8px 225px 8px / 8px 225px 8px 255px;
    border: 1px solid color-mix(in srgb, var(--fp-dash) 55%, transparent);
    background: var(--fp-accent-soft);
    color: var(--fp-ink);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .text-link {
    display: inline-flex;
    margin-top: 1rem;
    color: var(--fp-accent-strong);
    font-size: 0.92rem;
    font-weight: 700;
    text-decoration: none;
  }

  .featured-skills {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .featured-skill {
    display: grid;
    gap: 0.55rem;
    justify-items: center;
    padding: 0.85rem 0.7rem;
    text-align: center;
    border-radius: 255px 10px 225px 10px / 10px 225px 10px 255px;
    border: 1px solid color-mix(in srgb, var(--fp-dash) 50%, transparent);
