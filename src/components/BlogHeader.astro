---
import { SITE_TITLE } from "../consts";

interface Props {
  /** 博客标题 */
  title?: string;
  /** 副标题 */
  subtitle?: string;
  /** Logo 图片地址 */
  logo?: string;
  /** Emoji 尾巴（对应标题汉字的 Emoji 数组） */
  emojiTail?: string[];
  /** 标题 HTML 标签 */
  tag?: "h1" | "h2" | "h3" | "div";
  /** 标题链接 */
  href?: string;
}

const {
  title = SITE_TITLE,
  subtitle = "记录生活、踩坑与折腾",
  logo = "/avatar.jpeg",
  emojiTail = ["🐱", "🌸", "📚", "🎮"],
  tag: TitleTag = "h1",
  href = "/",
} = Astro.props;

// 标题字符数组
const titleChars = [...title];
---

<div class="blog-header">
  {/* Emoji 尾巴背景 */}
  {
    emojiTail.length > 0 && (
      <div class="emoji-tail" aria-hidden="true">
        {emojiTail.map((emoji, i) => (
          <span
            class="split-char"
            style={`--delay: ${(i * 0.6 - 3).toFixed(1)}s`}
          >
            {emoji}
          </span>
        ))}
      </div>
    )
  }

  {/* Logo */}
  <a href={href} class="blog-logo-wrap">
    <img src={logo} alt={title} class="blog-logo" />
  </a>

  {/* 标题 + 副标题 */}
  <div class="blog-text">
    <TitleTag class="header-title">
      {
        titleChars.map((char, i) => (
          <span
            class="split-char"
            style={`--delay: ${((i + 1) * 0.1).toFixed(2)}s`}
          >
            {char}
          </span>
        ))
      }
    </TitleTag>
    <div class="header-subtitle">{subtitle}</div>
  </div>
</div>

<style>
  /* ---------- 容器 ---------- */
  .blog-header {
    contain: layout;
    display: flex;
    align-items: center;
    gap: 0.5em;
    position: relative;
    margin: clamp(1rem, 2rem, 5vh) 1rem min(1rem, 5vh);
    line-height: 1.4;
    color: rgb(24 24 27);
    user-select: none;
  }

  :global(html.dark) .blog-header {
    color: rgb(244 244 245);
  }

  /* ---------- Logo ---------- */
  .blog-logo-wrap {
    flex-shrink: 0;
    text-decoration: none;
  }

  .blog-logo {
    height: 3em;
    width: 3em;
    border-radius: 50%;
    object-fit: cover;
    box-shadow:
      0 1px 3px rgb(0 0 0 / 0.12),
      0 4px 12px rgb(0 0 0 / 0.08);
    transition: transform 0.3s;
  }

  .blog-header:hover .blog-logo {
    transform: scale(1.05);
  }

  /* ---------- 标题 ---------- */
  .header-title {
    font-size: 1.5em;
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
  }

  .header-title > .split-char {
    display: inline-block;
    animation: 3.14s infinite alternate char-weight;
    animation-delay: var(--delay);
    animation-play-state: paused;
  }

  .blog-header:hover .header-title > .split-char {
    animation-play-state: running;
  }

  @keyframes char-weight {
    0% {
      font-weight: 600;
    }
    38.2% {
      font-weight: 300;
    }
    100% {
      font-weight: 900;
    }
  }

  /* ---------- 副标题 ---------- */
  .header-subtitle {
    opacity: 0.5;
    font-size: 0.8em;
    margin-top: 0.1em;
  }

  /* ---------- Emoji 尾巴 ---------- */
  .emoji-tail {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(0, 1fr));
    align-content: center;
    justify-items: center;
    position: absolute;
    opacity: 0.15;
    inset: 0;
    font-size: 4rem;
    transition: opacity 1s;
    filter: blur(2px);
    pointer-events: none;
    z-index: -2;
  }

  :global(html.dark) .emoji-tail {
    opacity: 0.12;
  }

  .emoji-tail > .split-char {
    animation: 5s infinite alternate emoji-floating;
    animation-delay: var(--delay);
    animation-play-state: paused;
  }

  .blog-header:hover .emoji-tail {
    opacity: 0.4;
  }

  :global(html.dark) .blog-header:hover .emoji-tail {
    opacity: 0.35;
  }

  .blog-header:hover .emoji-tail > .split-char {
    animation-play-state: running;
  }

  @keyframes emoji-floating {
    50% {
      transform: translate(-12px, -4px) scale(1.2);
      filter: blur(4px);
    }
    100% {
      transform: translate(-4px, -12px) scale(0.9);
      filter: blur(1px);
    }
  }

  /* ---------- 响应式 ---------- */
  @media (max-width: 640px) {
    .blog-header {
      margin: 1rem 0.75rem;
    }
    .blog-logo {
      height: 2.5em;
      width: 2.5em;
    }
    .header-title {
      font-size: 1.2em;
    }
    .emoji-tail {
      font-size: 3rem;
    }
  }
</style>
