---
import { GISCUS_CONFIG } from "../consts";

interface Props {
  pageKey: string;
  pageTitle: string;
}

const { pageKey, pageTitle } = Astro.props;
const scriptConfig = {
  repo: GISCUS_CONFIG.repo,
  repoId: GISCUS_CONFIG.repoId,
  category: GISCUS_CONFIG.category,
  categoryId: GISCUS_CONFIG.categoryId,
  mapping: GISCUS_CONFIG.mapping,
  strict: GISCUS_CONFIG.strict,
  reactionsEnabled: GISCUS_CONFIG.reactionsEnabled,
  emitMetadata: GISCUS_CONFIG.emitMetadata,
  inputPosition: GISCUS_CONFIG.inputPosition,
  lang: GISCUS_CONFIG.lang,
  pageKey,
  pageTitle,
};
---

<div class="giscus-card">
  <span class="giscus-tape" aria-hidden="true"></span>
  <span class="giscus-tab" aria-hidden="true"></span>
  <div class="giscus-header">
    <p class="giscus-hint">来过，就留下你的足迹吧！</p>
    <span class="giscus-underline" aria-hidden="true"></span>
  </div>
  <div class="giscus-body">
    <div id="giscus-comments"></div>
  </div>
</div>

<script is:inline define:vars={{ giscusConfig: scriptConfig }}>
  const GISCUS_PATH_KEY = "__giscusLastPath";
  const GISCUS_CONFIG_KEY = "__giscusConfig";
  const GISCUS_HANDLERS_BOUND_KEY = "__giscusHandlersBound";
  const globalWindow = window;

  globalWindow[GISCUS_CONFIG_KEY] = giscusConfig;

  function getGiscusTheme() {
    return document.documentElement.classList.contains("dark")
      ? "dark"
      : "light";
  }

  function getConfig() {
    const container = document.getElementById("giscus-comments");
    const config = globalWindow[GISCUS_CONFIG_KEY];

    if (!(container instanceof HTMLElement) || !config) return null;

    const {
      repo,
      repoId,
      category,
      categoryId,
      mapping,
      strict,
      reactionsEnabled,
      emitMetadata,
      inputPosition,
      lang,
      pageKey,
      pageTitle,
    } = config;

    if (!repo || !repoId || !category || !categoryId) return null;

    return {
      container,
      repo,
      repoId,
      category,
      categoryId,
      mapping: mapping || "pathname",
      strict: strict || "0",
      reactionsEnabled: reactionsEnabled || "1",
      emitMetadata: emitMetadata || "0",
      inputPosition: inputPosition || "top",
      lang: lang || "zh-CN",
      pageKey: pageKey || window.location.pathname,
      pageTitle: pageTitle || document.title,
    };
  }

  function clearGiscus() {
    const container = document.getElementById("giscus-comments");
    if (!(container instanceof HTMLElement)) return;
    container.innerHTML = "";
  }

  function initGiscus() {
    const config = getConfig();
    if (!config) {
      const container = document.getElementById("giscus-comments");
      if (container) {
        container.innerHTML =
          '<p class="text-sm" style="color:var(--fp-muted)">Giscus 评论未配置。</p>';
      }
      return;
    }

    const currentPath = window.location.pathname;
    if (globalWindow[GISCUS_PATH_KEY] === currentPath) return;

    clearGiscus();

    const script = document.createElement("script");
    script.src = "https://giscus.app/client.js";
    script.async = true;
    script.crossOrigin = "anonymous";
    script.setAttribute("data-repo", config.repo);
    script.setAttribute("data-repo-id", config.repoId);
    script.setAttribute("data-category", config.category);
    script.setAttribute("data-category-id", config.categoryId);
    script.setAttribute("data-mapping", config.mapping);
    script.setAttribute("data-strict", config.strict);
    script.setAttribute("data-reactions-enabled", config.reactionsEnabled);
    script.setAttribute("data-emit-metadata", config.emitMetadata);
    script.setAttribute("data-input-position", config.inputPosition);
    script.setAttribute("data-theme", getGiscusTheme());
    script.setAttribute("data-lang", config.lang);
    script.setAttribute("data-loading", "lazy");

    if (config.mapping === "specific") {
      script.setAttribute("data-term", config.pageKey);
      script.setAttribute("data-title", config.pageTitle);
    }

    config.container.appendChild(script);
    globalWindow[GISCUS_PATH_KEY] = currentPath;
  }

  function updateGiscusTheme() {
    const frame = document.querySelector("iframe.giscus-frame");
    if (!(frame instanceof HTMLIFrameElement) || !frame.contentWindow) return;

    frame.contentWindow.postMessage(
      {
        giscus: {
          setConfig: {
            theme: getGiscusTheme(),
          },
        },
      },
      "https://giscus.app",
    );
  }

  initGiscus();

  if (!globalWindow[GISCUS_HANDLERS_BOUND_KEY]) {
    const observer = new MutationObserver(() => {
      updateGiscusTheme();
    });

    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });

    document.addEventListener("astro:after-swap", initGiscus);
    document.addEventListener("astro:page-load", updateGiscusTheme);
    globalWindow[GISCUS_HANDLERS_BOUND_KEY] = true;
  }
</script>

<style is:global>
  .giscus-card {
    --gi-tilt: -0.12deg;
    position: relative;
    margin-top: 2rem;
    padding: 1.35rem 1.15rem 1.15rem;
    border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;
    background: linear-gradient(
      160deg,
      var(--fp-paper) 0%,
      color-mix(in srgb, var(--fp-warm) 90%, transparent) 100%
    );
    border: 1px solid color-mix(in srgb, var(--fp-dash) 55%, transparent);
    box-shadow:
      var(--fp-shadow),
      inset 0 1px color-mix(in srgb, var(--fp-paper) 70%, transparent);
    transform: rotate(var(--gi-tilt));
    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .giscus-card:hover {
    transform: translateY(-2px) rotate(0deg);
    border-color: color-mix(in srgb, var(--fp-accent) 35%, var(--fp-dash));
    box-shadow:
      var(--fp-small-shadow),
      inset 0 1px color-mix(in srgb, var(--fp-paper) 70%, transparent);
  }

  .giscus-tape {
    position: absolute;
    top: -7px;
    left: 28px;
    z-index: 2;
    width: 36px;
    height: 14px;
    background-color: rgba(200, 170, 230, 0.68);
    background-image: repeating-linear-gradient(
      45deg,
      rgba(255, 255, 255, 0.22) 0 2px,
      transparent 2px 6px
    );
    border-radius: 2px;
    box-shadow: 0 2px 6px rgba(82, 64, 38, 0.1);
    transform: rotate(-3deg);
    pointer-events: none;
  }

  html.dark .giscus-tape {
    background-color: rgba(130, 100, 160, 0.56);
    background-image: repeating-linear-gradient(
      45deg,
      rgba(0, 0, 0, 0.12) 0 2px,
      transparent 2px 6px
    );
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);
  }

  .giscus-tab {
    position: absolute;
    top: 20px;
    right: -5px;
    z-index: -1;
    width: 5px;
    height: 44px;
    border: 1px dashed color-mix(in srgb, var(--fp-dash) 50%, transparent);
    border-left: 0;
    border-radius: 0 6px 6px 0;
    background: #b8a0d8;
    box-shadow: 2px 3px 0 rgba(82, 64, 38, 0.06);
    pointer-events: none;
    transition:
      width 0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
      right 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  html.dark .giscus-tab {
    border-color: rgba(225, 230, 245, 0.08);
    background: #7a5a8a;
    box-shadow: 3px 3px 0 rgba(0, 0, 0, 0.14);
  }

  .giscus-card:hover .giscus-tab {
    right: -10px;
    width: 10px;
  }

  .giscus-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .giscus-hint {
    margin: 0;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--fp-ink-soft);
    letter-spacing: 0.02em;
  }

  .giscus-underline {
    display: block;
    width: 3.5em;
    height: 5px;
    margin-top: 5px;
    background-color: var(--fp-accent);
    opacity: 0.65;
    mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 50 8'><path d='M1 4.5 C 10 2.5 16 5 24 3.6 C 32 2.2 40 5.2 47 3.4' fill='none' stroke='black' stroke-width='5'/></svg>");
    -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 50 8'><path d='M1 4.5 C 10 2.5 16 5 24 3.6 C 32 2.2 40 5.2 47 3.4' fill='none' stroke='black' stroke-width='5'/></svg>");
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    mask-size: contain;
    -webkit-mask-size: contain;
  }

  .giscus-body {
    min-height: 200px;
  }

  .giscus-body iframe.giscus-frame {
    border-radius: 8px;
    border: none;
    width: 100%;
  }

  @media (max-width: 680px) {
    .giscus-card {
      border-radius: 255px 12px 225px 12px / 12px 225px 12px 255px;
      padding: 1.15rem 0.95rem 1rem;
      transform: none;
    }

    .giscus-tape {
      left: 20px;
    }
  }
</style>
