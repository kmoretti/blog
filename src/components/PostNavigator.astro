---
import { Icon } from "astro-icon/components";
import type { PostEntry } from "../lib/utils";

interface Props {
  prevPost?: PostEntry;
  nextPost?: PostEntry;
}

const { prevPost, nextPost } = Astro.props;
const hasNoPosts = !prevPost && !nextPost;
---

<nav class="post-navigator" aria-label="文章导航">
  {
    hasNoPosts ? (
      <div class="nav-empty">
        <Icon
          name="material-symbols:article-rounded"
          width="20"
          height="20"
          class="nav-empty-icon"
        />
        <span>暂无其他文章</span>
      </div>
    ) : (
      <div class="nav-grid">
        {prevPost ? (
          <a href={`/posts/${prevPost.slug}/`} class="nav-card nav-card-prev">
            <span class="nav-card-label">
              <Icon
                name="material-symbols:arrow-back-rounded"
                width="16"
                height="16"
              />
              <span>上一篇</span>
            </span>
            <span class="nav-card-title">{prevPost.data.title}</span>
            <span class="nav-card-date">
              {prevPost.data.date.toLocaleDateString("zh-CN", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </span>
          </a>
        ) : (
          <div class="nav-card nav-card-disabled">
            <span class="nav-card-label">
              <Icon
                name="material-symbols:arrow-back-rounded"
                width="16"
                height="16"
              />
              <span>上一篇</span>
            </span>
            <span class="nav-card-title">暂无上一篇文章</span>
          </div>
        )}
        {nextPost ? (
          <a href={`/posts/${nextPost.slug}/`} class="nav-card nav-card-next">
            <span class="nav-card-label">
              <span>下一篇</span>
              <Icon
                name="material-symbols:arrow-forward-rounded"
                width="16"
                height="16"
              />
            </span>
            <span class="nav-card-title">{nextPost.data.title}</span>
            <span class="nav-card-date">
              {nextPost.data.date.toLocaleDateString("zh-CN", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </span>
          </a>
        ) : (
          <div class="nav-card nav-card-disabled">
            <span class="nav-card-label">
              <span>下一篇</span>
              <Icon
                name="material-symbols:arrow-forward-rounded"
                width="16"
                height="16"
              />
            </span>
            <span class="nav-card-title">暂无下一篇文章</span>
          </div>
        )}
      </div>
    )
  }
</nav>

<style>
  .post-navigator {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .nav-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.25rem;
    border-radius: 0.75rem;
    border: 1px solid var(--fp-dash);
    background-color: var(--fp-paper);
    backdrop-filter: blur(4px);
    font-size: 0.875rem;
    color: var(--fp-muted);
  }

  .nav-empty-icon {
    opacity: 0.6;
  }

  .nav-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  @media (max-width: 640px) {
    .nav-grid {
      grid-template-columns: 1fr;
    }
  }

  .nav-card {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 1rem 1.25rem;
    border-radius: 0.75rem;
    border: 1px solid var(--fp-dash);
    background-color: var(--fp-paper);
    backdrop-filter: blur(4px);
    box-shadow: var(--fp-shadow);
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
  }

  a.nav-card {
    text-decoration: none;
  }

  a.nav-card:hover {
    border-color: var(--fp-accent);
    box-shadow: var(--fp-shadow);
  }

  .nav-card-next {
    text-align: right;
    align-items: flex-end;
  }

  .nav-card-disabled {
    opacity: 0.55;
    cursor: default;
  }

  .nav-card-label {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--fp-muted);
  }

  .nav-card-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--fp-ink);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  a.nav-card .nav-card-title {
    color: var(--fp-accent-strong);
  }

  .nav-card-date {
    font-size: 0.75rem;
    color: var(--fp-ink-soft);
  }
</style>
