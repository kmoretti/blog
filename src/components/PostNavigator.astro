---
import { Icon } from "astro-icon/components";
import type { PostEntry } from "../lib/utils";

interface Props {
  prevPost?: PostEntry;
  nextPost?: PostEntry;
}

const { prevPost, nextPost } = Astro.props;
const hasNoPosts = !prevPost && !nextPost;
---

<nav class="post-navigator" aria-label="文章导航">
  {
    hasNoPosts ? (
      <div class="nav-empty">
        <Icon
          name="material-symbols:article-rounded"
          width="20"
          height="20"
          class="nav-empty-icon"
        />
        <span>暂无其他文章</span>
      </div>
    ) : (
      <div class="nav-grid">
        {
          prevPost ? (
            <a href={`/posts/${prevPost.slug}/`} class="nav-card nav-card-prev">
              <span class="nav-card-label">
                <Icon
                  name="material-symbols:arrow-back-rounded"
                  width="16"
                  height="16"
                />
                <span>上一篇</span>
              </span>
              <span class="nav-card-title">{prevPost.data.title}</span>
              <span class="nav-card-date">
                {prevPost.data.date.toLocaleDateString("zh-CN", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </span>
            </a>
          ) : (
            <div class="nav-card nav-card-disabled">
              <span class="nav-card-label">
                <Icon
                  name="material-symbols:arrow-back-rounded"
                  width="16"
                  height="16"
                />
                <span>上一篇</span>
              </span>
              <span class="nav-card-title">暂无上一篇文章</span>
            </div>
          )
        }
        {
          nextPost ? (
            <a href={`/posts/${nextPost.slug}/`} class="nav-card nav-card-next">
              <span class="nav-card-label">
                <span>下一篇</span>
                <Icon
                  name="material-symbols:arrow-forward-rounded"
                  width="16"
                  height="16"
                />
              </span>
              <span class="nav-card-title">{nextPost.data.title}</span>
              <span class="nav-card-date">
                {nextPost.data.date.toLocaleDateString("zh-CN", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </span>
            </a>
          ) : (
            <div class="nav-card nav-card-disabled">
              <span class="nav-card-label">
                <span>下一篇</span>
                <Icon
                  name="material-symbols:arrow-forward-rounded"
                  width="16"
                  height="16"
                />
              </span>
              <span class="nav-card-title">暂无下一篇文章</span>
            </div>
          )
        }
      </div>
    )
  }
</nav>

<style>
  .post-navigator {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .nav-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.25rem;
    border-radius: 0.75rem;
    border: 1px solid rgb(228 228 231 / 0.8);
    background-color: rgb(255 255 255 / 0.8);
    backdrop-filter: blur(4px);
    font-size: 0.875rem;
    color: rgb(113 113 122);
  }

  :global(html.dark) .nav-empty {
    border-color: rgb(63 63 70 / 0.8);
    background-color: rgb(39 39 42 / 0.75);
    color: rgb(161 161 170);
  }

  .nav-empty-icon {
    opacity: 0.6;
  }

  .nav-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  @media (max-width: 640px) {
    .nav-grid {
      grid-template-columns: 1fr;
    }
  }

  .nav-card {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 1rem 1.25rem;
    border-radius: 0.75rem;
    border: 1px solid rgb(228 228 231 / 0.8);
    background-color: rgb(255 255 255 / 0.8);
    backdrop-filter: blur(4px);
    box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
  }

  :global(html.dark) .nav-card {
    border-color: rgb(63 63 70 / 0.8);
    background-color: rgb(39 39 42 / 0.75);
  }

  a.nav-card {
    text-decoration: none;
  }

  a.nav-card:hover {
    border-color: rgb(59 130 246 / 0.5);
    box-shadow: 0 2px 8px 0 rgb(59 130 246 / 0.1);
  }

  :global(html.dark) a.nav-card:hover {
    border-color: rgb(96 165 250 / 0.5);
    box-shadow: 0 2px 8px 0 rgb(96 165 250 / 0.08);
  }

  .nav-card-next {
    text-align: right;
    align-items: flex-end;
  }

  .nav-card-disabled {
    opacity: 0.55;
    cursor: default;
  }

  .nav-card-label {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: rgb(113 113 122);
  }

  :global(html.dark) .nav-card-label {
    color: rgb(161 161 170);
  }

  .nav-card-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: rgb(24 24 27);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  :global(html.dark) .nav-card-title {
    color: rgb(228 228 231);
  }

  a.nav-card .nav-card-title {
    color: rgb(37 99 235);
  }

  :global(html.dark) a.nav-card .nav-card-title {
    color: rgb(147 197 253);
  }

  .nav-card-date {
    font-size: 0.75rem;
    color: rgb(161 161 170);
  }

  :global(html.dark) .nav-card-date {
    color: rgb(113 113 122);
  }
</style>
