---
import type { MarkdownHeading } from "astro";

interface Props {
  headings: MarkdownHeading[];
  mode: "mobile" | "desktop";
  enableTracking?: boolean;
}

const { headings, mode, enableTracking = false } = Astro.props;

const items = headings.filter(
  ({ depth, slug, text }) => depth >= 2 && depth <= 4 && slug && text.trim(),
);

const panelClass = "toc-panel rounded-2xl border p-4";
const linkClass =
  "toc-link block rounded-lg px-3 py-2 text-sm no-underline transition";
---

{
  items.length > 0 &&
    (mode === "mobile" ? (
      <details class={`mb-6 lg:hidden ${panelClass}`}>
        <summary class="toc-heading cursor-pointer list-none text-sm font-semibold">
          文章目录
        </summary>
        <nav class="mt-3 space-y-1" aria-label="文章目录">
          {items.map((item) => (
            <a
              href={`#${item.slug}`}
              data-toc-link={item.slug}
              data-active="false"
              class={linkClass}
              style={`padding-left: ${0.75 + (item.depth - 2) * 0.75}rem;`}
            >
              {item.text}
            </a>
          ))}
        </nav>
      </details>
    ) : (
      <aside class="hidden lg:block">
        <div class={`sticky top-24 ${panelClass}`}>
          <p class="toc-heading mb-3 text-sm font-semibold">文章目录</p>
          <nav class="space-y-1" aria-label="文章目录">
            {items.map((item) => (
              <a
                href={`#${item.slug}`}
                data-toc-link={item.slug}
                data-active="false"
                class={linkClass}
                style={`padding-left: ${0.75 + (item.depth - 2) * 0.75}rem;`}
              >
                {item.text}
              </a>
            ))}
          </nav>
        </div>
      </aside>
    ))
}

<script is:inline define:vars={{ enableTracking }}>
  (() => {
    if (!enableTracking) return;

    const init = () => {
      const links = Array.from(document.querySelectorAll("[data-toc-link]"));

      if (links.length === 0) return;

      const sections = [];
      const seen = new Set();

      for (const link of links) {
        const slug = link.getAttribute("data-toc-link");

        if (!slug || seen.has(slug)) continue;

        const heading = document.getElementById(slug);

        if (!heading) continue;

        seen.add(slug);
        sections.push({ slug, heading });
      }

      if (sections.length === 0) return;

      const setActive = (slug) => {
        for (const link of links) {
          link.dataset.active = String(
            link.getAttribute("data-toc-link") === slug,
          );
        }
      };

      const updateActive = () => {
        let activeSlug = sections[0].slug;

        for (const section of sections) {
          if (section.heading.getBoundingClientRect().top <= 140) {
            activeSlug = section.slug;
          } else {
            break;
          }
        }

        setActive(activeSlug);
      };

      updateActive();
      window.addEventListener("scroll", updateActive, { passive: true });
      window.addEventListener("resize", updateActive);

      return () => {
        window.removeEventListener("scroll", updateActive);
        window.removeEventListener("resize", updateActive);
      };
    };

    window.__blogTocCleanup?.();
    window.__blogTocCleanup = init();
  })();
</script>

<style>
  .toc-panel {
    border-color: var(--fp-dash);
    background-color: var(--fp-paper);
  }

  .toc-heading {
    color: var(--fp-ink);
  }

  .toc-link {
    color: var(--fp-ink-soft);
    border-radius: 0.5rem;
  }

  .toc-link:hover {
    background-color: var(--fp-accent-soft);
    color: var(--fp-ink);
  }

  .toc-link[data-active="true"] {
    background-color: var(--fp-accent-soft);
    font-weight: 500;
    color: var(--fp-ink);
  }
</style>
