---
import type { TaxonomyKey } from "../lib/utils";
import { slugifyTaxonomy } from "../lib/utils";

interface Props {
  items: string[];
  type: TaxonomyKey;
}

const { items, type } = Astro.props;
const isTag = type === "tags";
const chipClass = isTag
  ? "border-[var(--fp-dash)] bg-[var(--fp-warm)] text-[var(--fp-ink-soft)] hover:border-[var(--fp-accent)] hover:bg-[var(--fp-accent-soft)]"
  : "border-[var(--fp-dash)] bg-[var(--fp-warm)] text-[var(--fp-ink-soft)] hover:border-[var(--fp-accent)] hover:bg-[var(--fp-accent-soft)]";
---

{
  items.length > 0 && (
    <div class="flex flex-wrap justify-center gap-2.5">
      {items.map((item) => (
        <a
          href={`/${type}/${slugifyTaxonomy(item)}/`}
          class:list={[
            "inline-flex items-center rounded-2xl border px-3 py-1.5 text-sm font-medium tracking-tight no-underline shadow-sm transition duration-200 hover:-translate-y-0.5",
            chipClass,
          ]}
        >
          {isTag ? `# ${item}` : item}
        </a>
      ))}
    </div>
  )
}
