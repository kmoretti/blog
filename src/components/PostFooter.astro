---
import { Icon } from "astro-icon/components";
import { SITE_URL } from "../consts";
import type { PostEntry } from "../lib/utils";
import { formatDate, slugifyTaxonomy } from "../lib/utils";

interface Props {
  post: PostEntry;
}

const { post } = Astro.props;
const fullUrl = `${SITE_URL}/posts/${post.slug}/`;

const rewardQRCodes = [
  {
    label: "微信",
    src: "/avatar.jpeg",
    borderColor: "rgb(62, 159, 80)",
  },
  {
    label: "支付宝",
    src: "/avatar.jpeg",
    borderColor: "rgb(66, 90, 239)",
  },
];
---

<div class="post-footer">
  {/* ── 作者信息卡片 ── */}
  <section class="author-card">
    <div class="copyright-badge">
      <Icon name="material-symbols:copyright-rounded" width="32" height="32" />
    </div>

    <div class="card-body">
      <h3 class="card-title">{post.data.title}</h3>
      <p class="card-url">{fullUrl}</p>

      <div class="meta-grid">
        <div class="meta-item">
          <span class="meta-label">文章作者</span>
          <span class="meta-value">克喵 Moretti</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">发布时间</span>
          <span class="meta-value">{formatDate(post.data.date)}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">版权信息</span>
          <a
            href="https://creativecommons.org/licenses/by-nc-sa/4.0/deed.zh-hans"
            target="_blank"
            rel="noopener"
            class="meta-value copyright-link"
          >
            CC BY-NC-SA 4.0
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* ── 标签 + 打赏 ── */}
  <section class="post-bottom">
    <div class="tags-list">
      {
        post.data.tags.map((tag) => (
          <a href={`/tags/${slugifyTaxonomy(tag)}/`} class="tag-chip">
            <span class="tag-name">#{tag}</span>
          </a>
        ))
      }
    </div>
    <button class="reward-btn" id="reward-open-btn">
      <Icon name="material-symbols:favorite-rounded" width="16" height="16" />
      <span>打赏</span>
    </button>
  </section>
</div>

{/* ── 打赏弹窗 ── */}
<div class="reward-overlay" id="reward-overlay">
  <div class="reward-mask" id="reward-mask"></div>
  <div class="reward-panel">
    <div class="panel-header">
      <h2>打赏中心</h2>
      <button class="close-btn" id="reward-close-btn" aria-label="关闭">
        <Icon name="material-symbols:close-rounded" width="20" height="20" />
      </button>
    </div>
    <div class="panel-content">
      <p class="reward-title">感谢你赐予我前进的力量</p>
      <div class="qr-group">
        {
          rewardQRCodes.map((qr) => (
            <div class="qr-item">
              <img
                src={qr.src}
                alt={qr.label}
                class="qr-image"
                style={`border-color: ${qr.borderColor}`}
                width="130"
                height="130"
              />
              <span class="qr-label">{qr.label}</span>
            </div>
          ))
        }
      </div>
      <a href="https://sponsor.081531.xyz/sponsors" class="donor-link">
        <span class="donor-link-text">赞赏者名单</span>
        <span class="donor-link-desc">因为你们的支持让我意识到写文章的价值</span
        >
      </a>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    function bind() {
      const overlay = document.getElementById("reward-overlay");
      const openBtn = document.getElementById("reward-open-btn");
      const closeBtn = document.getElementById("reward-close-btn");
      const mask = document.getElementById("reward-mask");
      if (!overlay || !openBtn || !closeBtn || !mask) return;
      if (openBtn.dataset.bound === "1") return;

      function open() {
        overlay.classList.add("active");
        document.body.style.overflow = "hidden";
      }
      function close() {
        overlay.classList.remove("active");
        document.body.style.overflow = "";
      }

      openBtn.addEventListener("click", open);
      closeBtn.addEventListener("click", close);
      mask.addEventListener("click", close);
      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape" && overlay.classList.contains("active")) close();
      });

      openBtn.dataset.bound = "1";
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", bind, { once: true });
    } else {
      bind();
    }
    document.addEventListener("astro:page-load", bind);
  })();
</script>

<style>
  .post-footer {
    margin-top: 2.5rem;
    border: 1px solid var(--fp-dash);
    border-radius: 0.75rem;
    background-color: var(--fp-paper);
    overflow: hidden;
  }

  .author-card {
    position: relative;
    padding: 1.5rem;
  }

  .copyright-badge {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    color: var(--fp-dash);
    opacity: 0.5;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--fp-ink);
    margin: 0;
  }

  .card-url {
    font-size: 0.8rem;
    color: var(--fp-muted);
    word-break: break-all;
    margin: 0;
  }

  .meta-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  @media (max-width: 640px) {
    .meta-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .meta-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--fp-muted);
  }

  .meta-value {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--fp-ink);
    word-break: break-word;
  }

  a.copyright-link {
    color: var(--fp-accent-strong);
    text-decoration: none;
  }

  a.copyright-link:hover {
    text-decoration: underline;
  }

  .post-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    border-top: 1px solid var(--fp-dash);
  }

  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-chip {
    display: inline-flex;
    align-items: center;
    height: 2rem;
    padding: 0 0.65rem;
    border-radius: 0.5rem;
    border: 1px solid var(--fp-dash);
    background-color: var(--fp-warm);
    font-size: 0.8rem;
    color: var(--fp-ink-soft);
    text-decoration: none;
    white-space: nowrap;
    transition:
      border-color 0.2s,
      background-color 0.2s;
  }

  .tag-chip:hover {
    border-color: var(--fp-accent);
    background-color: var(--fp-accent-soft);
  }

  .reward-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    height: 2rem;
    padding: 0 0.9rem;
    border-radius: 0.5rem;
    border: 1px solid rgb(244 63 94 / 0.3);
    background-color: color-mix(in srgb, var(--fp-warm) 80%, rgb(255 241 242));
    font-size: 0.8rem;
    font-weight: 500;
    color: rgb(225 29 72);
    cursor: pointer;
    transition:
      background-color 0.2s,
      border-color 0.2s,
      box-shadow 0.2s;
  }

  .reward-btn:hover {
    background-color: color-mix(in srgb, var(--fp-warm) 60%, rgb(254 226 226));
    border-color: rgb(244 63 94 / 0.5);
    box-shadow: 0 2px 8px rgb(244 63 94 / 0.12);
  }

  .reward-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .reward-overlay.active {
    pointer-events: auto;
    opacity: 1;
  }

  .reward-mask {
    position: absolute;
    inset: 0;
    background-color: rgb(0 0 0 / 0.2);
    backdrop-filter: blur(4px);
  }

  .reward-panel {
    position: relative;
    width: 92%;
    max-width: 420px;
    border-radius: 1rem;
    border: 1px solid var(--fp-dash);
    background-color: var(--fp-paper);
    box-shadow: var(--fp-shadow);
    padding: 1.5rem;
    transform: translateY(20px);
    transition: transform 0.2s ease;
  }

  .reward-overlay.active .reward-panel {
    transform: translateY(0);
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .panel-header h2 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--fp-ink);
  }

  .close-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.35rem;
    border: none;
    border-radius: 0.5rem;
    background-color: transparent;
    color: var(--fp-muted);
    cursor: pointer;
    transition:
      background-color 0.15s,
      color 0.15s;
  }

  .close-btn:hover {
    background-color: var(--fp-warm);
    color: var(--fp-ink);
  }

  .panel-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .reward-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: rgb(225 29 72);
    margin: 0;
  }

  .qr-group {
    display: flex;
    gap: 1.5rem;
  }

  .qr-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
  }

  .qr-image {
    width: 130px;
    height: 130px;
    border-radius: 0.75rem;
    border: 2px solid;
    object-fit: cover;
  }

  .qr-label {
    font-size: 0.8rem;
    color: var(--fp-muted);
  }

  .donor-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    width: calc(100% - 1rem);
    padding: 0.75rem 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid var(--fp-dash);
    background-color: var(--fp-warm);
    text-decoration: none;
    transition:
      background-color 0.2s,
      border-color 0.2s,
      box-shadow 0.2s;
  }

  .donor-link:hover {
    border-color: var(--fp-accent);
    background-color: var(--fp-accent-soft);
    box-shadow: var(--fp-soft-shadow);
  }

  .donor-link-text {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--fp-ink);
  }

  .donor-link-desc {
    font-size: 0.75rem;
    color: var(--fp-muted);
  }
</style>
