---
import Key from "./Key.astro";
---

<div
  class="rounded-2xl border border-zinc-200 bg-zinc-50/90 p-3 dark:border-zinc-700 dark:bg-zinc-800/70"
>
  <label for="post-search-panel" class="sr-only">搜索文章</label>
  <div class="mb-2 flex items-center justify-between gap-3 text-xs text-zinc-500 dark:text-zinc-400">
    <span>站内搜索</span>
    <span class="inline-flex items-center gap-1">
      快捷键
      <Key cmd code="K" press="post-search:toggle" prevent />
    </span>
  </div>
  <div id="post-search-panel" class="pagefind-search"></div>
</div>

<script is:inline>
  /** @type {Promise<any> | undefined} */
  let pagefindUiPromise;
  /** @type {Promise<boolean> | undefined} */
  let pagefindAssetsPromise;

  const PAGEFIND_UI_PATH = "/pagefind/pagefind-ui.js";
  const PAGEFIND_UI_STYLE_PATH = "/pagefind/pagefind-ui.css";
  const PAGEFIND_UI_STYLE_ID = "pagefind-ui-styles";

  function renderUnavailableMessage(host) {
    host.innerHTML =
      '<p class="text-sm text-zinc-500 dark:text-zinc-400">搜索索引暂不可用，请先执行构建后再试。</p>';
    host.dataset.ready = "1";
  }

  /**
   * @param {HTMLElement} host
   */
  function focusPagefindInput(host) {
    const tryFocus = () => {
      const input = host.querySelector("input");
      if (!(input instanceof HTMLInputElement)) return false;
      input.focus();
      input.select();
      return true;
    };

    if (tryFocus()) return;

    requestAnimationFrame(() => {
      if (tryFocus()) return;
      window.setTimeout(tryFocus, 160);
    });
  }

  /**
   * @param {any} module
   */
  function resolvePagefindUi(module) {
    if (typeof window.PagefindUI === "function") return window.PagefindUI;
    if (typeof module?.PagefindUI === "function") return module.PagefindUI;
    if (typeof module?.default?.PagefindUI === "function") {
      return module.default.PagefindUI;
    }

    throw new Error("Pagefind UI failed to initialize.");
  }

  async function hasPagefindAssets() {
    if (!pagefindAssetsPromise) {
      pagefindAssetsPromise = fetch(PAGEFIND_UI_PATH, { method: "HEAD" })
        .then((response) => response.ok)
        .catch(() => false);
    }

    return pagefindAssetsPromise;
  }

  function ensurePagefindStyles() {
    if (document.getElementById(PAGEFIND_UI_STYLE_ID)) return;

    const link = document.createElement("link");
    link.id = PAGEFIND_UI_STYLE_ID;
    link.rel = "stylesheet";
    link.href = PAGEFIND_UI_STYLE_PATH;
    document.head.append(link);
  }

  /**
   * @param {HTMLElement} container
   */
  function syncTheme(container) {
    const isDark = document.documentElement.classList.contains("dark");
    container.dataset.theme = isDark ? "dark" : "light";
  }

  async function loadPagefind() {
    if (!pagefindUiPromise) {
      pagefindUiPromise = import(PAGEFIND_UI_PATH);
    }

    return pagefindUiPromise;
  }

  async function mountPagefind() {
    const host = document.querySelector(".pagefind-search");
    if (!(host instanceof HTMLElement)) return;

    syncTheme(host);

    if (host.dataset.ready === "1") {
      focusPagefindInput(host);
      return;
    }

    if (!(await hasPagefindAssets())) {
      renderUnavailableMessage(host);
      return;
    }

    try {
      ensurePagefindStyles();
      const module = await loadPagefind();
      const PagefindUI = resolvePagefindUi(module);

      new PagefindUI({
        element: host,
        showImages: false,
        showSubResults: true,
        excerptLength: 18,
        resetStyles: false,
        translations: {
          placeholder: "搜索文章、标签、分类",
          clear_search: "清空搜索",
          load_more: "加载更多",
          search_label: "站内搜索",
          filters_label: "筛选",
          zero_results: "没有找到相关结果",
          many_results: "找到 [COUNT] 条结果",
          one_result: "找到 1 条结果",
          alt_search: "搜索 [SEARCH_TERM]",
        },
      });

      host.dataset.ready = "1";
      focusPagefindInput(host);
    } catch (error) {
      console.error(error);
      renderUnavailableMessage(host);
    }
  }

  function onThemeChange() {
    const host = document.querySelector(".pagefind-search");
    if (host instanceof HTMLElement) syncTheme(host);
  }

  document.addEventListener("post-search:open", mountPagefind);
  document.addEventListener("astro:page-load", onThemeChange);
  document.addEventListener("theme-changed", onThemeChange);
</script>

<style>
  .pagefind-search {
    --pagefind-ui-scale: 0.95;
    --pagefind-ui-primary: rgb(39 39 42);
    --pagefind-ui-text: rgb(39 39 42);
    --pagefind-ui-background: transparent;
    --pagefind-ui-border: rgb(212 212 216);
    --pagefind-ui-tag: rgb(244 244 245);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0.9rem;
    --pagefind-ui-image-border-radius: 0.75rem;
    --pagefind-ui-font: "Noto Sans SC", sans-serif;
  }

  .pagefind-search[data-theme="dark"] {
    --pagefind-ui-primary: rgb(244 244 245);
    --pagefind-ui-text: rgb(228 228 231);
    --pagefind-ui-border: rgb(82 82 91);
    --pagefind-ui-tag: rgb(39 39 42);
  }

  .pagefind-search :global(.pagefind-ui__search-input),
  .pagefind-search :global(.pagefind-ui__result),
  .pagefind-search :global(.pagefind-ui__button) {
    @apply bg-white/90 dark:bg-zinc-900/80;
  }

  .pagefind-search :global(.pagefind-ui__search-input) {
    @apply text-zinc-900 placeholder:text-zinc-400 dark:text-zinc-100 dark:placeholder:text-zinc-500;
  }

  .pagefind-search :global(.pagefind-ui__result-link) {
    @apply text-zinc-900 no-underline dark:text-zinc-100;
  }

  .pagefind-search :global(.pagefind-ui__result-excerpt),
  .pagefind-search :global(.pagefind-ui__message) {
    @apply text-zinc-600 dark:text-zinc-400;
  }
</style>
