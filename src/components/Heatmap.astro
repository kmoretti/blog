---
import { getColorIntensity, getHeatmapData } from "../lib/heatmap";

const desktopRows = 5;
const desktopCols = 30;
const mobileRows = 4;
const mobileCols = 20;

const desktopCellCount = desktopRows * desktopCols;
const mobileCellCount = mobileRows * mobileCols;

const heatmapData = await getHeatmapData(
  Math.max(desktopCellCount, mobileCellCount),
);
const maxWordCount = Math.max(...heatmapData.map((d) => d.wordCount));
const grid = heatmapData;
---

<div class="heatmap-container relative space-y-2">
  <div class="heatmap-grid grid gap-1.5">
    {
      grid.map((day) => {
        const colorClass = getColorIntensity(day.wordCount, maxWordCount);
        const dateStr = day.date.toLocaleDateString("zh-CN", {
          year: "numeric",
          month: "long",
          day: "numeric",
        });

        return (
          <div
            class:list={["group relative aspect-square", colorClass]}
            data-date={dateStr}
            data-count={day.wordCount}
          >
            {day.wordCount > 0 && (
              <div class="tooltip absolute -top-10 left-1/2 z-10 hidden -translate-x-1/2 whitespace-nowrap bg-gray-900 px-2 py-1 text-xs text-white group-hover:block dark:bg-gray-200 dark:text-gray-800">
                <div class="font-medium">{dateStr}</div>
                <div>{day.wordCount} 字</div>
                <div class="absolute left-1/2 h-2 w-2 -translate-x-1/2 rotate-45 bg-gray-900 dark:bg-gray-200" />
              </div>
            )}
          </div>
        );
      })
    }
  </div>
</div>

<style>
  .heatmap-grid {
    grid-template-columns: repeat(30, 1fr);
  }

  @media (max-width: 639px) {
    .heatmap-grid {
      grid-template-columns: repeat(20, 1fr);
    }

    .heatmap-grid > :not(:nth-last-child(-n + 80)) {
      display: none;
    }
  }

  .heatmap-cell:hover {
    transform: scale(1.1);
    z-index: 20;
  }

  .tooltip {
    animation: fadeIn 0.15s ease-in;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translate(-50%, -4px);
    }
    to {
      opacity: 1;
      transform: translate(-50%, 0);
    }
  }
</style>
