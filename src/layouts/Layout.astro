---
import { ViewTransitions } from "astro:transitions";
import aisummaryCss from "../assets/styles/aisummary.css?url";
import Header from "../components/Header.astro";
import { cn } from "../lib/utils";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  image?: string;
  className?: string;
}

const {
  title,
  description,
  image = "/static/banner.png",
  className,
} = Astro.props;
---

<html lang="zh-CN">
  <head>
    <!-- Global Metadata -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <!-- Tell the browser we support both schemes (prevents UA auto-darkening + helps form controls/scrollbars) -->
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Theme initialization - must run before paint to prevent dark-mode "white flash" -->
    <script is:inline>
      (() => {
        const STORAGE_KEY = "theme";

        function getStoredTheme() {
          try {
            const theme = localStorage.getItem(STORAGE_KEY);
            return theme === "dark" || theme === "light" ? theme : null;
          } catch {
            return null;
          }
        }

        function getSystemTheme() {
          return window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }

        function resolveTheme() {
          return getStoredTheme() ?? getSystemTheme();
        }

        function applyTheme(doc) {
          const theme = resolveTheme();
          doc.documentElement.classList.toggle("dark", theme === "dark");
        }

        // 1) First paint
        applyTheme(document);

        // 2) Astro View Transitions swaps <html> attributes from the next document.
        //    Apply theme to `event.newDocument` so the swapped-in <html> keeps the "dark" class.
        document.addEventListener("astro:before-swap", (event) => {
          // Astro provides `newDocument` on the event object.
          const newDocument = event?.newDocument;
          if (newDocument) applyTheme(newDocument);
        });

        // 3) Re-apply after navigation just in case
        document.addEventListener("astro:page-load", () =>
          applyTheme(document),
        );

        // 4) If user never chose a theme, follow system changes live
        const media = window.matchMedia("(prefers-color-scheme: dark)");
        media.addEventListener("change", () => {
          if (getStoredTheme() === null) applyTheme(document);
        });
      })();
    </script>

    <meta name="title" content={title} />
    <!-- Self-hosted fonts via @fontsource (imported in src/styles/global.css). Avoids Google Fonts and local system font reliance. -->
    <meta name="description" content={description} />
    <link rel="canonical" href={Astro.url} />
    <script
      is:inline
      defer
      src="https://umami.ohdragonboi.cn/analytics"
      data-website-id="20db53a2-22e0-4ed1-b379-8d1136fb40c8"></script>
    <script is:inline defer src="/js/GmeekBSZ.js"></script>
    <script is:inline defer src="/js/lightbox.js"></script>
    <!-- AISummary 配置与样式 -->
    <script is:inline defer src="/js/aisummary.config.js"></script>
    <link rel="stylesheet" href={aisummaryCss} />
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />

    <ViewTransitions />
    <style is:inline>
      :root {
        --app-bg: #ffffff;
        background-color: var(--app-bg);
        color-scheme: light;
      }
      html.dark {
        --app-bg: #18181b;
        background-color: var(--app-bg);
        color-scheme: dark;
      }
      ::view-transition-old(root),
      ::view-transition-new(root) {
        background: var(--app-bg) !important;
      }
    </style>
  </head>
  <body
    class="bg-white font-sans text-zinc-900 antialiased transition-colors dark:bg-zinc-900 dark:text-zinc-200"
  >
    <div class={cn("max-w-xl mx-auto p-4", className)}>
      <Header />
      <slot />
    </div>
  </body>
</html>
