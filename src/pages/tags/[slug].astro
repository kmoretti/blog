---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import {
  formatDate,
  getTaxonomyMap,
  slugifyTaxonomy,
  sortPostsByDate,
} from "../../lib/utils";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const tagMap = getTaxonomyMap(posts, "tags");

  return [...tagMap.values()].map((tag) => ({
    params: { slug: tag.slug },
    props: {
      tag,
      posts: sortPostsByDate(
        posts.filter((post) =>
          post.data.tags.some((item) => slugifyTaxonomy(item) === tag.slug),
        ),
      ),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<Layout
  title={`${tag.name} | 标签`}
  description={`标签 ${tag.name} 下的 ${posts.length} 篇文章`}
  className="flex min-h-svh max-w-4xl flex-col"
>
  <main class="flex flex-col gap-5 pb-16">
    <section class="space-y-1">
      <p class="text-sm text-zinc-500 dark:text-zinc-400">
        <a href="/tags/" class="no-underline hover:underline">标签</a>
        <span class="mx-1">/</span>
        <span>{tag.name}</span>
      </p>
      <h1 class="text-xl font-semibold">{tag.name}</h1>
      <p class="text-sm text-zinc-500 dark:text-zinc-400">
        共 {posts.length} 篇文章
      </p>
    </section>

    <ul class="flex flex-col gap-2">
      {
        posts.map((post) => (
          <li>
            <a href={`/posts/${post.slug}/`} class="group flex flex-col gap-1">
              <div class="flex justify-between gap-3">
                <span class="group-hover:underline">{post.data.title}</span>
                <span class="text-nowrap text-zinc-500">
                  {formatDate(post.data.date)}
                </span>
              </div>
              {post.data.description && (
                <span class="text-sm text-zinc-400 dark:text-zinc-400">
                  {post.data.description}
                </span>
              )}
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</Layout>
