---
import { SITE_TITLE } from "../consts";
import Layout from "../layouts/Layout.astro";

const pageTitle = `页面走丢了 | ${SITE_TITLE}`;
const pageDescription = "你似乎来到了一个不存在的页面。";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  className="!max-w-full !p-0"
>
  <main class="not-found-root">
    <div class="not-found-wrap">
      <span class="tape tape--top-right" aria-hidden="true"></span>
      <article class="not-found-paper">
        <header class="not-found-header">
          <span class="label-pill">页面走丢了</span>
          <p class="not-found-code" aria-hidden="true">404</p>
          <h1>找不到这个页面</h1>
          <p class="not-found-lead">
            这个地址可能已经移动、删除，或者从未存在。
          </p>
        </header>
        <div class="not-found-actions">
          <a class="not-found-action" href="/">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
              ></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg
            >
            <span>返回首页</span>
          </a>
          <a class="not-found-action" href="/posts/1/">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"
              ></path><polyline points="14 2 14 8 20 8"></polyline><line
                x1="16"
                x2="8"
                y1="13"
                y2="13"></line><line x1="16" x2="8" y1="17" y2="17"></line></svg
            >
            <span>浏览归档</span>
          </a>
        </div>
      </article>
    </div>
  </main>
</Layout>

<style>
  .not-found-root {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 100px);
    padding: 3rem 1rem;
    box-sizing: border-box;
  }

  .not-found-wrap {
    position: relative;
    width: 100%;
    max-width: 480px;
  }

  .tape {
    position: absolute;
    width: 44px;
    height: 26px;
    background: var(--fp-tape);
    border-radius: 2px;
    opacity: 0.8;
    z-index: 1;
  }

  .tape--top-right {
    top: -12px;
    right: 24px;
    transform: rotate(6deg);
  }

  .tape::after {
    content: "";
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      45deg,
      rgba(255, 255, 255, 0.25) 0 2px,
      transparent 2px 7px
    );
    border-radius: 2px;
  }

  html.dark .tape::after {
    background: repeating-linear-gradient(
      45deg,
      rgba(0, 0, 0, 0.15) 0 2px,
      transparent 2px 7px
    );
  }

  .not-found-paper {
    position: relative;
    padding: 44px 36px 36px;
    text-align: center;
    background: var(--fp-paper);
    border-radius: 255px 18px 225px 18px / 18px 225px 18px 255px;
    box-shadow: var(--fp-shadow);
  }

  .not-found-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-bottom: 20px;
  }

  .label-pill {
    display: inline-block;
    padding: 3px 14px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.3px;
    color: var(--fp-ink-soft);
    background: var(--fp-warm);
    border: 1px solid var(--fp-dash);
  }

  .not-found-code {
    margin: 6px 0 0;
    font-size: 80px;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -2px;
    color: var(--fp-accent);
    user-select: none;
  }

  .not-found-header h1 {
    margin: 6px 0 0;
    font-size: 18px;
    font-weight: 700;
    line-height: 1.4;
    color: var(--fp-ink);
  }

  .not-found-lead {
    max-width: 400px;
    margin: 10px auto 0;
    font-size: 14px;
    line-height: 1.8;
    color: var(--fp-muted);
  }

  .not-found-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-top: 18px;
  }

  .not-found-action {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-width: 128px;
    padding: 9px 20px;
    border: 0;
    color: var(--fp-ink-soft);
    background: transparent;
    font: inherit;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    z-index: 1;
    transition:
      color 0.2s ease,
      transform 0.2s ease;
  }

  .not-found-action::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--fp-warm);
    z-index: -1;
    border-radius: 4px;
    box-shadow: inset 0 0 0 1px var(--fp-dash);
    transition:
      background 0.2s ease,
      box-shadow 0.2s ease;
  }

  html.dark .not-found-action::before {
    box-shadow: none;
  }

  .not-found-action:hover {
    color: var(--fp-accent-strong);
    transform: translateY(-1px);
  }

  .not-found-action:hover::before {
    background: var(--fp-accent-soft);
    box-shadow: inset 0 0 0 1px var(--fp-accent);
  }

  .not-found-action svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  @media (max-width: 480px) {
    .not-found-root {
      min-height: calc(100vh - 80px);
      padding: 2rem 0.75rem;
    }

    .not-found-paper {
      padding: 32px 20px 28px;
    }

    .not-found-code {
      font-size: 60px;
    }

    .not-found-header h1 {
      font-size: 16px;
    }

    .not-found-action {
      min-width: 110px;
      padding: 8px 14px;
      font-size: 12px;
    }
  }
</style>
