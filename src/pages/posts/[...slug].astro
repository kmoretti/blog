---
import { Icon } from "astro-icon/components";
import { type CollectionEntry, getCollection } from "astro:content";
import Giscus from "../../components/Giscus.astro";
import PostFooter from "../../components/PostFooter.astro";
import PostMetaChips from "../../components/PostMetaChips.astro";
import PostNavigator from "../../components/PostNavigator.astro";
import ProseA from "../../components/ProseA.astro";
import Layout from "../../layouts/Layout.astro";
import {
  formatDate,
  formatNumber,
  getPostReadingStats,
  sortPostsByDate,
} from "../../lib/utils";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const sorted = sortPostsByDate(posts);
  return sorted.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      ...post,
      prevPost: index > 0 ? sorted[index - 1] : undefined,
      nextPost: index < sorted.length - 1 ? sorted[index + 1] : undefined,
    },
  }));
}

type Props = CollectionEntry<"posts"> & {
  prevPost?: CollectionEntry<"posts">;
  nextPost?: CollectionEntry<"posts">;
};

const { prevPost, nextPost } = Astro.props;
const post: CollectionEntry<"posts"> = Astro.props;
const { Content } = await post.render();
const stats = getPostReadingStats(post.body);
---

<Layout
  title={post.data.title + " | 喵洛阁"}
  description={post.data.description}
  image={post.data.image}
  className="flex min-h-svh max-w-6xl flex-col"
>
  <main class="pb-16">
    <header class="mx-auto mb-6 max-w-3xl space-y-3 text-center">
      <h1 class="text-xl font-medium">{post.data.title}</h1>
      {
        post.data.description && (
          <p class="text-sm text-zinc-600 dark:text-zinc-400">
            {post.data.description}
          </p>
        )
      }
      <div class="mx-auto flex max-w-2xl flex-wrap justify-center gap-2.5 pt-1">
        <div
          class="inline-flex items-center gap-1.5 rounded-2xl border border-zinc-200/80 bg-white/80 px-3 py-1.5 text-sm text-zinc-600 shadow-sm backdrop-blur-sm dark:border-zinc-700/80 dark:bg-zinc-800/75 dark:text-zinc-300"
        >
          <Icon
            name="material-symbols:calendar-month-rounded"
            width="18"
            height="18"
          />
          <span>{formatDate(post.data.date)}</span>
        </div>
        <div
          class="inline-flex items-center gap-1.5 rounded-2xl border border-zinc-200/80 bg-white/80 px-3 py-1.5 text-sm text-zinc-600 shadow-sm backdrop-blur-sm dark:border-zinc-700/80 dark:bg-zinc-800/75 dark:text-zinc-300"
        >
          <Icon
            name="material-symbols:auto-stories-rounded"
            width="18"
            height="18"
          />
          <span
            >{
              `\u63a8\u8350\u9605\u8bfb ${stats.readingMinutes} \u5206\u949f`
            }</span
          >
        </div>
        <div
          class="inline-flex items-center gap-1.5 rounded-2xl border border-zinc-200/80 bg-white/80 px-3 py-1.5 text-sm text-zinc-600 shadow-sm backdrop-blur-sm dark:border-zinc-700/80 dark:bg-zinc-800/75 dark:text-zinc-300"
        >
          <Icon
            name="material-symbols:article-rounded"
            width="18"
            height="18"
          />
          <span>{`${formatNumber(stats.wordCount)} \u5b57`}</span>
        </div>
        <div
          id="busuanzi_container_page_pv"
          data-busuanzi-item
          class="inline-flex items-center gap-1.5 rounded-2xl border border-zinc-200/80 bg-white/80 px-3 py-1.5 text-sm text-zinc-600 shadow-sm backdrop-blur-sm dark:border-zinc-700/80 dark:bg-zinc-800/75 dark:text-zinc-300"
        >
          <Icon
            name="material-symbols:visibility-rounded"
            width="18"
            height="18"
          />
          <span>{"\u6d4f\u89c8\u91cf"}</span>
          <span
            id="busuanzi_value_page_pv"
            class="font-semibold text-zinc-900 dark:text-zinc-100"></span>
        </div>
        <div
          id="busuanzi_container_site_uv"
          data-busuanzi-item
          class="inline-flex items-center gap-1.5 rounded-2xl border border-zinc-200/80 bg-white/80 px-3 py-1.5 text-sm text-zinc-600 shadow-sm backdrop-blur-sm dark:border-zinc-700/80 dark:bg-zinc-800/75 dark:text-zinc-300"
        >
          <Icon name="material-symbols:group-rounded" width="18" height="18" />
          <span>{"\u89c2\u4f17\u6570"}</span>
          <span
            id="busuanzi_value_site_uv"
            class="font-semibold text-zinc-900 dark:text-zinc-100"></span>
        </div>
      </div>
      <div class="flex flex-col gap-3 pt-2">
        <PostMetaChips items={post.data.categories} type="categories" />
        <PostMetaChips items={post.data.tags} type="tags" />
      </div>
    </header>

    <div class="mx-auto max-w-3xl">
      <article
        id="content"
        class="markdown-body"
        data-lightbox-root
        data-pagefind-body
        data-pagefind-sort={post.data.date.toISOString()}
      >
        {
          post.data.summary && (
            <div class="aisummary-container not-prose">
              <div class="aisummary-title">
                <i class="aisummary-title-icon">
                  <Icon
                    name="material-symbols:smart-toy-outline-rounded"
                    width="20"
                    height="20"
                  />
                </i>
                <div class="aisummary-title-text">AI 摘要</div>
                <div class="aisummary-tag" id="aisummary-tag">
                  AI
                </div>
              </div>
              <div
                class="aisummary-explanation"
                data-ai-summary={post.data.summary}
              >
                {post.data.summary}
              </div>
              <div class="aisummary-disclaimer">
                本摘要由 AI 生成，仅供参考，内容准确性请以原文为准。
              </div>
            </div>
          )
        }
        <div class="hidden">
          <span data-pagefind-meta="title">{post.data.title}</span>
          <span data-pagefind-meta="description">{post.data.description}</span>
          <span data-pagefind-meta="date">{formatDate(post.data.date)}</span>
          {
            post.data.categories.map((category) => (
              <span data-pagefind-filter={`categories:${category}`}>
                {category}
              </span>
            ))
          }
          {
            post.data.tags.map((tag) => (
              <span data-pagefind-filter={`tags:${tag}`}>{tag}</span>
            ))
          }
        </div>
        <Content components={{ a: ProseA }} />
      </article>
    </div>

    <div class="mx-auto max-w-3xl">
      <PostFooter post={post} />
    </div>

    <div class="mx-auto max-w-3xl">
      <PostNavigator prevPost={prevPost} nextPost={nextPost} />
    </div>

    <div class="mx-auto mt-10 max-w-3xl">
      <Giscus pageKey={Astro.url.pathname} pageTitle={post.data.title} />
    </div>
  </main>
  <script is:inline defer src="/js/GmeekTOC.js"></script>
  <script is:inline defer src="/js/aisummary.js"></script>
</Layout>
