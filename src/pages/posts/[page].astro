---
import type { Page } from "astro";
import { Icon } from "astro-icon/components";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import Key from "../../components/Key.astro";
import PostSearch from "../../components/PostSearch.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import Layout from "../../layouts/Layout.astro";
import { formatDate, sortPostsByDate } from "../../lib/utils";

export async function getStaticPaths({ paginate }: any) {
  const collection = await getCollection("posts");
  const posts = sortPostsByDate(collection);

  return paginate(posts, { pageSize: 7 });
}

const { page }: { page: Page<CollectionEntry<"posts">> } = Astro.props;
---

<Layout
  title={SITE_TITLE}
  description={SITE_DESCRIPTION}
  className="max-w-100px flex min-h-svh flex-col justify-center"
>
  <main class="flex flex-col gap-4">
    <section class="flex flex-col gap-3">
      <div class="flex flex-wrap items-center gap-2">
        <a
          href="/tags/"
          class="inline-flex items-center gap-1.5 rounded-full border border-zinc-200 bg-zinc-100/80 px-3 py-1.5 text-sm font-medium text-zinc-700 no-underline transition hover:border-zinc-300 hover:bg-zinc-200 dark:border-zinc-700 dark:bg-zinc-800/80 dark:text-zinc-200 dark:hover:border-zinc-600 dark:hover:bg-zinc-700"
        >
          <Icon name="material-symbols:tag-rounded" width="18" height="18" />
          标签
        </a>
        <a
          href="/categories/"
          class="inline-flex items-center gap-1.5 rounded-full border border-zinc-200 bg-zinc-100/80 px-3 py-1.5 text-sm font-medium text-zinc-700 no-underline transition hover:border-zinc-300 hover:bg-zinc-200 dark:border-zinc-700 dark:bg-zinc-800/80 dark:text-zinc-200 dark:hover:border-zinc-600 dark:hover:bg-zinc-700"
        >
          <Icon
            name="material-symbols:dashboard-rounded"
            width="18"
            height="18"
          />
          分类
        </a>
        <button
          type="button"
          id="search-toggle"
          class="inline-flex items-center gap-1.5 rounded-full border border-zinc-200 bg-zinc-100/80 px-3 py-1.5 text-sm font-medium text-zinc-700 transition hover:border-zinc-300 hover:bg-zinc-200 dark:border-zinc-700 dark:bg-zinc-800/80 dark:text-zinc-200 dark:hover:border-zinc-600 dark:hover:bg-zinc-700"
          aria-expanded="false"
          aria-controls="post-search-container"
        >
          <Icon name="material-symbols:search-rounded" width="18" height="18" />
          <span class="hidden items-center gap-1 pl-1 text-xs text-zinc-500 dark:text-zinc-400 sm:inline-flex">
            <Key cmd code="K" press="post-search:toggle" prevent />
          </span>
          搜索
        </button>
      </div>

      <div id="post-search-container" class="hidden">
        <PostSearch />
      </div>
    </section>

    <ul class="flex flex-col gap-1.5">
      {
        page.data.map((post) => (
          <li>
            <a href={`/posts/${post.slug}/`} class="group flex flex-col gap-1">
              <div class="flex justify-between gap-3">
                <span class="group-hover:underline">{post.data.title}</span>
                <span class="text-nowrap text-zinc-500">
                  {formatDate(post.data.date)}
                </span>
              </div>
              {post.data.description && (
                <span class="text-sm text-zinc-400 dark:text-zinc-400">
                  {post.data.description}
                </span>
              )}
            </a>
          </li>
        ))
      }
    </ul>

    {
      page.lastPage > 1 && (
        <nav class="flex items-center justify-center gap-2 text-sm">
          {page.url.prev && (
            <a
              href={page.url.prev}
              class="text-zinc-700 hover:underline dark:text-zinc-300"
            >
              &larr; 上一页
            </a>
          )}

          <span class="text-zinc-500">
            第 {page.currentPage} / {page.lastPage} 页
          </span>

          {page.url.next && (
            <a
              href={page.url.next}
              class="text-zinc-700 hover:underline dark:text-zinc-300"
            >
              下一页 &rarr;
            </a>
          )}
        </nav>
      )
    }
  </main>
</Layout>

<script is:inline>
  function setupPostSearch() {
    const button = document.getElementById("search-toggle");
    const container = document.getElementById("post-search-container");
    if (
      !(button instanceof HTMLButtonElement) ||
      !(container instanceof HTMLElement)
    )
      return;
    if (button.dataset.bound === "1") return;

    function toggleSearch(forceExpanded) {
      const nextExpanded =
        typeof forceExpanded === "boolean"
          ? forceExpanded
          : button.getAttribute("aria-expanded") !== "true";

      button.setAttribute("aria-expanded", String(nextExpanded));
      container.classList.toggle("hidden", !nextExpanded);

      if (nextExpanded) {
        document.dispatchEvent(new CustomEvent("post-search:open"));
      }
    }

    button.addEventListener("click", () => {
      toggleSearch();
    });

    if (window.__postSearchToggleHandler) {
      document.removeEventListener(
        "post-search:toggle",
        window.__postSearchToggleHandler,
      );
    }

    window.__postSearchToggleHandler = () => {
      toggleSearch();
    };

    document.addEventListener(
      "post-search:toggle",
      window.__postSearchToggleHandler,
    );

    button.dataset.bound = "1";
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupPostSearch, {
      once: true,
    });
  } else {
    setupPostSearch();
  }

  document.addEventListener("astro:page-load", setupPostSearch);
</script>
