---
import Layout from "../../layouts/Layout.astro";
import { fetchFriends } from "../../lib/friends";

const pageTitle = "友情链接 | 喵洛阁";
const pageDescription = "我的朋友们";
const friendsData = await fetchFriends();
---

<Layout
  title={pageTitle}
  description={pageDescription}
  className="max-w-100px flex h-svh flex-col justify-center"
>
  <main class="space-y-6">
    <header class="mb-6 flex items-start justify-between gap-4">
      <div class="space-y-2">
        <nav aria-label="Breadcrumb" class="text-sm text-zinc-500">
          <a href="/" class="hover:underline">喵洛阁</a>
          <span class="mx-1">/</span>
        </nav>
        <h1 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-100">
          朋友们
        </h1>
      </div>
      <div class="flex shrink-0 gap-2">
        <a
          href="/friends/fcircle/"
          class="inline-flex items-center rounded-full border border-zinc-200 bg-white px-3 py-1.5 text-sm text-zinc-600 transition hover:border-zinc-300 hover:text-zinc-900 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-300 dark:hover:border-zinc-700 dark:hover:text-zinc-100"
        >
          朋友圈
        </a>
        <a
          href="/friends/friends/"
          class="inline-flex items-center rounded-full border border-zinc-200 bg-white px-3 py-1.5 text-sm text-zinc-600 transition hover:border-zinc-300 hover:text-zinc-900 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-300 dark:hover:border-zinc-700 dark:hover:text-zinc-100"
        >
          详细
        </a>
      </div>
    </header>
    <div
      class="grid grid-cols-6 gap-3 p-4 sm:grid-cols-8 sm:gap-4 md:grid-cols-10 lg:grid-cols-10"
    >
      {
        friendsData.map((friend) => (
          <a
            href={friend.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative flex items-center justify-center transition-transform hover:z-10 hover:scale-110"
            title={friend.name}
          >
            <img
              src={friend.avatar}
              alt={friend.name}
              class="w-12 rounded-full object-cover sm:w-14 md:w-16"
              loading="lazy"
            />
            <span class="pointer-events-none absolute bottom-[-2rem] left-1/2 z-50 -translate-x-1/2 whitespace-nowrap rounded bg-gray-800 px-2 py-1 text-sm text-white opacity-0 transition-opacity group-hover:opacity-100 dark:bg-gray-200 dark:text-gray-800">
              {friend.name}
            </span>
          </a>
        ))
      }
    </div>
    <div class="mt-6 flex justify-center gap-4">
      <a
        href="/friends/exchange/"
        class="text-zinc-500 hover:underline dark:text-zinc-500"
      >
        交换友链 &rarr;
      </a>
      <span class="text-zinc-300 dark:text-zinc-700">|</span>
      <a
        href="/friends/fcircle/"
        class="text-zinc-500 hover:underline dark:text-zinc-500"
      >
        朋友圈 &rarr;
      </a>
    </div>
  </main>
</Layout>
