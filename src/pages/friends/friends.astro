---
import Layout from "../../layouts/Layout.astro";
import { fetchFriends } from "../../lib/friends";
import type { FriendItem } from "../../lib/friends";
import { LATENCY_API_URL } from "../../consts";

interface RemoteLinkItem {
  name?: string;
  link?: string;
  link_page?: string;
  latency?: number;
  reachable?: boolean;
}

interface RemoteLinkPayload {
  link_data?: RemoteLinkItem[];
}

const pageTitle = "友链详情 | 喵洛阁";
const pageDescription = "友情链接详细页面";

const normalizeUrl = (value?: string) =>
  value?.trim().replace(/^`|`$/g, "").replace(/\/+$/, "") ?? "";
const normalizeTagList = (value?: string) =>
  (value ?? "")
    .split(",")
    .map((item) => item.trim())
    .filter(Boolean);

const getHost = (value: string) => {
  try {
    return new URL(value).host.replace(/^www\./, "");
  } catch {
    return value;
  }
};

const formatLatency = (latency?: number) => {
  if (!latency || Number.isNaN(latency)) return "检测中";
  return latency < 1
    ? `${Math.round(latency * 1000)} MS`
    : `${latency.toFixed(1)} S`;
};

const getLatencyTone = (latency?: number, reachable?: boolean) => {
  if (reachable === false) return "down";
  if (!latency || Number.isNaN(latency)) return "idle";
  if (latency < 0.8) return "fast";
  if (latency < 1.8) return "ok";
  return "slow";
};

const friendsData = await fetchFriends();

let latencyMap = new Map<string, { latency?: number; reachable?: boolean }>();

try {
  const response = await fetch(LATENCY_API_URL);
  const remoteData = (await response.json()) as RemoteLinkPayload;
  latencyMap = new Map(
    (remoteData.link_data ?? []).flatMap((item) => {
      const entries: [string, { latency?: number; reachable?: boolean }][] = [];
      const payload = { latency: item.latency, reachable: item.reachable };
      if (item.link) entries.push([normalizeUrl(item.link), payload]);
      if (item.link_page) entries.push([normalizeUrl(item.link_page), payload]);
      return entries;
    }),
  );
} catch {
  latencyMap = new Map();
}

const friends = friendsData.map((friend) => {
  const siteUrl = normalizeUrl(friend.url);
  const linksUrl = normalizeUrl(friend.links);
  const latencyInfo = latencyMap.get(siteUrl) ?? latencyMap.get(linksUrl);

  return {
    ...friend,
    url: siteUrl,
    links: linksUrl,
    snapshot: normalizeUrl(friend.snapshot),
    feed: normalizeUrl(friend.feed),
    desc: friend.desc?.trim() ?? "",
    tags: normalizeTagList(friend.tags),
    host: getHost(siteUrl),
    latency: latencyInfo?.latency,
    reachable: latencyInfo?.reachable,
    latencyText: formatLatency(latencyInfo?.latency),
    latencyTone: getLatencyTone(latencyInfo?.latency, latencyInfo?.reachable),
  };
});
---

<Layout
  title={pageTitle}
  description={pageDescription}
  className="max-w-[1100px] px-4 py-6"
>
  <main class="friends-detail space-y-8">
    <header class="space-y-4">
      <div class="flex items-start justify-between gap-4">
        <div class="space-y-2">
          <nav
            aria-label="Breadcrumb"
            class="text-sm text-zinc-500 dark:text-zinc-400"
          >
            <a href="/" class="hover:underline">喵洛阁</a>
            <span class="mx-1">/</span>
            <a href="/friends/" class="hover:underline">朋友们</a>
            <span class="mx-1">/</span>
          </nav>
          <h1 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-100">
            友链详情
          </h1>
          <p
            class="max-w-2xl text-sm leading-6 text-zinc-600 dark:text-zinc-400"
          >
            保留简洁页作为入口，这里补充站点截图、订阅地址、标签和最近一次延迟检测结果。
          </p>
        </div>
        <div class="flex shrink-0 gap-2">
          <a
            href="/friends/fcircle/"
            class="inline-flex items-center rounded-full border border-zinc-200 bg-white px-3 py-1.5 text-sm text-zinc-600 transition hover:border-zinc-400 hover:text-zinc-900 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-300 dark:hover:border-zinc-700 dark:hover:text-zinc-100"
          >
            朋友圈
          </a>
          <a
            href="/friends/"
            class="inline-flex items-center rounded-full border border-zinc-200 bg-white px-3 py-1.5 text-sm text-zinc-600 transition hover:border-zinc-400 hover:text-zinc-900 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-300 dark:hover:border-zinc-700 dark:hover:text-zinc-100"
          >
            简洁视图
          </a>
        </div>
      </div>
      <div
        class="flex flex-wrap gap-2 text-xs text-zinc-500 dark:text-zinc-400"
      >
        <span
          class="rounded-full border border-zinc-200 px-3 py-1 dark:border-zinc-800"
        >
          共 {friends.length} 位朋友
        </span>
        <span
          class="rounded-full border border-zinc-200 px-3 py-1 dark:border-zinc-800"
        >
          延迟数据源：fc.081531.xyz
        </span>
      </div>
    </header>

    <section class="friends-grid">
      {
        friends.map((friend) => (
          <article class="friend-card">
            <div class="friend-shot">
              {friend.snapshot ? (
                <img
                  src={friend.snapshot}
                  alt=""
                  class="friend-shot-image"
                  loading="lazy"
                />
              ) : (
                <div class="friend-shot-fallback" />
              )}
              <div class="friend-shot-mask" />
              <span
                class={`friend-latency friend-latency--${friend.latencyTone}`}
              >
                <span class="friend-latency-dot" />
                {friend.latencyText}
              </span>
            </div>

            <div class="friend-card__main">
              <a
                href={friend.url}
                target="_blank"
                rel="noopener noreferrer"
                class="friend-card__link"
              >
                <img
                    src={friend.avatar}
                    alt={friend.name}
                    class="friend-card__avatar"
                    loading="lazy"
                  />
                <span class="friend-card__body">
                  <strong class="friend-card__name">{friend.name}</strong>
                  <span class="friend-card__host">{friend.host}</span>
                  <span class="friend-card__desc">
                    {friend.desc || "这个朋友暂时还没有补充简介。"}
                  </span>
                </span>
              </a>

              {friend.feed && (
                <a
                  href={friend.feed}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="friend-card__rss"
                  aria-label={`${friend.name} 的 RSS`}
                  title="RSS"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="13"
                    height="13"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="lucide"
                  >
                    <path d="M4 11a9 9 0 0 1 9 9" />
                    <path d="M4 4a16 16 0 0 1 16 16" />
                    <circle cx="5" cy="19" r="1" />
                  </svg>
                </a>
              )}
            </div>

            <div class="friend-card__extra">
              {friend.tags.length > 0 && (
                <div class="friend-tags">
                  {friend.tags.map((tag) => (
                    <span class="friend-tag">{tag}</span>
                  ))}
                </div>
              )}

              <div class="friend-meta-grid">
                <div class="friend-meta-box">
                  <div class="friend-meta-label">主站</div>
                  <div class="friend-meta-value">{friend.host}</div>
                </div>
                <div class="friend-meta-box">
                  <div class="friend-meta-label">订阅</div>
                  {friend.feed ? (
                    <span class="friend-meta-value">已提供</span>
                  ) : (
                    <span class="friend-meta-value">未提供</span>
                  )}
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </section>
  </main>

  <style is:inline>
    .friends-detail {
      --friends-tape-0: #f5d742;
      --friends-tape-1: #f09bc0;
      --friends-tape-2: #86d993;
      --friends-tape-3: #87b9e8;
      --friends-tab-0: #7cb87c;
      --friends-tab-1: #6ba8d6;
      --friends-tab-2: #f5d742;
      --friends-tab-3: #e8a0b8;
      --friends-card-bg: rgba(255, 255, 255, 0.92);
      --friends-card-border: rgba(24, 24, 27, 0.10);
      --friends-card-shadow: 4px 5px 0 rgba(82, 64, 38, 0.08), 0 2px 8px rgba(15, 23, 42, 0.06);
      --friends-avatar-border: rgba(82, 64, 38, 0.12);
      --friends-avatar-shadow: 2px 3px 0 rgba(82, 64, 38, 0.08);
      --friends-shot-fallback: linear-gradient(
        135deg,
        rgba(245, 215, 66, 0.30),
        rgba(255, 255, 255, 0.92)
      );
      --friends-shot-mask: linear-gradient(
        to top,
        rgba(255, 255, 255, 0.98),
        rgba(255, 255, 255, 0.15) 45%,
        rgba(255, 255, 255, 0.02)
      );
      --friends-tag-bg: rgba(24, 24, 27, 0.04);
      --friends-meta-bg: rgba(24, 24, 27, 0.03);
      --friends-muted: #71717a;
      --friends-ink: #18181b;
      --friends-accent: #2563eb;
    }

    html.dark .friends-detail {
      --friends-tape-0: #a8862a;
      --friends-tape-1: #9e5f7a;
      --friends-tape-2: #4f7a55;
      --friends-tape-3: #4f6f8a;
      --friends-tab-0: #4a7a4a;
      --friends-tab-1: #3d6a8a;
      --friends-tab-2: #a8862a;
      --friends-tab-3: #8a5f70;
      --friends-card-bg: rgba(24, 24, 27, 0.88);
      --friends-card-border: rgba(255, 255, 255, 0.06);
      --friends-card-shadow: 4px 5px 0 rgba(0, 0, 0, 0.20), 0 2px 8px rgba(0, 0, 0, 0.12);
      --friends-avatar-border: rgba(225, 230, 245, 0.12);
      --friends-avatar-shadow: 2px 3px 0 rgba(0, 0, 0, 0.18);
      --friends-shot-fallback: linear-gradient(
        135deg,
        rgba(168, 134, 42, 0.20),
        rgba(24, 24, 27, 0.90)
      );
      --friends-shot-mask: linear-gradient(
        to top,
        rgba(24, 24, 27, 0.98),
        rgba(24, 24, 27, 0.20) 45%,
        rgba(24, 24, 27, 0.04)
      );
      --friends-tag-bg: rgba(255, 255, 255, 0.06);
      --friends-meta-bg: rgba(255, 255, 255, 0.04);
      --friends-muted: #a1a1aa;
      --friends-ink: #e4e4e7;
      --friends-accent: #93c5fd;
    }

    .friends-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      align-items: stretch;
      gap: 20px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .friend-card {
      --fcl-tilt: -0.25deg;
      --fcl-tape-color: var(--friends-tape-0);
      --fcl-tab-color: var(--friends-tab-0);
      position: relative;
      z-index: 1;
      border-radius: 10px;
      background: var(--friends-card-bg);
      box-shadow: var(--friends-card-shadow);
      isolation: isolate;
      transform: rotate(var(--fcl-tilt));
      transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
    }

    .friend-card:nth-child(4n+2) {
      --fcl-tilt: 0.22deg;
      --fcl-tape-color: var(--friends-tape-1);
      --fcl-tab-color: var(--friends-tab-1);
    }

    .friend-card:nth-child(4n+3) {
      --fcl-tilt: -0.12deg;
      --fcl-tape-color: var(--friends-tape-2);
      --fcl-tab-color: var(--friends-tab-2);
    }

    .friend-card:nth-child(4n+4) {
      --fcl-tilt: 0.3deg;
      --fcl-tape-color: var(--friends-tape-3);
      --fcl-tab-color: var(--friends-tab-3);
    }

    .friend-card:hover {
      z-index: 10;
    }

    .friend-card::before,
    .friend-card::after {
      content: "";
      position: absolute;
      pointer-events: none;
    }

    .friend-card::before {
      top: -8px;
      left: 22px;
      z-index: 5;
      width: 38px;
      height: 15px;
      background-color: var(--fcl-tape-color);
      background-image: repeating-linear-gradient(
        90deg,
        transparent,
        transparent 3px,
        rgba(255, 255, 255, 0.35) 3px,
        rgba(255, 255, 255, 0.35) 5px,
        transparent 5px,
        transparent 10px
      );
      box-shadow: 0 3px 8px rgba(82, 64, 38, 0.12);
      filter: saturate(0.92);
      transform: rotate(-3deg);
      border-radius: 2px;
    }

    html.dark .friend-card::before {
      box-shadow: 0 3px 8px rgba(0, 0, 0, 0.24);
    }

    .friend-card::after {
      top: 16px;
      right: -6px;
      z-index: -1;
      width: 6px;
      height: 48px;
      border: 1px dashed rgba(82, 64, 38, 0.12);
      border-left: 0;
      border-radius: 0 8px 8px 0;
      background: var(--fcl-tab-color);
      box-shadow: 2px 3px 0 rgba(82, 64, 38, 0.08);
      transition: width 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), right 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    html.dark .friend-card::after {
      border-color: rgba(225, 230, 245, 0.10);
      box-shadow: 3px 4px 0 rgba(0, 0, 0, 0.16);
    }

    .friend-card:hover {
      transform: translateY(-3px) rotate(0deg);
    }

    .friend-card:hover::after {
      right: -12px;
      width: 12px;
    }

    .friend-shot {
      position: relative;
      height: 10rem;
      overflow: hidden;
      border-radius: 10px 10px 0 0;
      background: var(--friends-shot-fallback);
    }

    .friend-shot-image {
      height: 100%;
      width: 100%;
      object-fit: cover;
      transition: transform 0.45s ease;
    }

    .friend-card:hover .friend-shot-image {
      transform: scale(1.03);
    }

    .friend-shot-fallback {
      height: 100%;
      width: 100%;
      background: var(--friends-shot-fallback);
    }

    .friend-shot-mask {
      position: absolute;
      inset: 0;
      background: var(--friends-shot-mask);
    }

    .friend-latency {
      position: absolute;
      top: 0.8rem;
      right: 0.8rem;
      z-index: 3;
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      border-radius: 999px;
      border: 1px solid transparent;
      padding: 0.3rem 0.65rem;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      backdrop-filter: blur(10px);
    }

    .friend-latency-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: currentColor;
      flex-shrink: 0;
    }

    .friend-latency--fast,
    .friend-latency--ok {
      background: color-mix(in srgb, #86d993 28%, transparent);
      border-color: color-mix(in srgb, #86d993 50%, transparent);
      color: #166534;
    }

    html.dark .friend-latency--fast,
    html.dark .friend-latency--ok {
      background: #22c55e;
      border-color: #16a34a;
      color: #fff;
      backdrop-filter: none;
    }

    .friend-latency--slow {
      background: rgba(245, 158, 11, 0.14);
      border-color: rgba(245, 158, 11, 0.3);
      color: #b45309;
    }

    html.dark .friend-latency--slow {
      background: #f59e0b;
      border-color: #d97706;
      color: #fff;
      backdrop-filter: none;
    }

    .friend-latency--down {
      background: rgba(244, 63, 94, 0.14);
      border-color: rgba(244, 63, 94, 0.3);
      color: #be123c;
    }

    html.dark .friend-latency--down {
      background: #f43f5e;
      border-color: #e11d48;
      color: #fff;
      backdrop-filter: none;
    }

    .friend-latency--idle {
      background: rgba(113, 113, 122, 0.12);
      border-color: rgba(113, 113, 122, 0.18);
      color: var(--friends-muted);
    }

    html.dark .friend-latency--idle {
      background: #71717a;
      border-color: #52525b;
      color: #fff;
      backdrop-filter: none;
    }

    .friend-card__main {
      position: relative;
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 14px 18px 0;
      margin-top: -1.5rem;
    }

    .friend-card__link {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      min-width: 0;
      flex: 1;
      text-decoration: none;
      color: inherit;
    }

    img.friend-card__avatar {
      flex-shrink: 0;
      display: block;
      width: 58px;
      height: 58px;
      border: 1px solid var(--friends-avatar-border);
      border-radius: 9px;
      background: var(--friends-card-bg);
      box-shadow: var(--friends-avatar-shadow);
      object-fit: cover;
      transform: rotate(-2deg);
      transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
    }

    .friend-card:hover img.friend-card__avatar {
      border-color: var(--friends-accent);
      box-shadow: 3px 5px 0 rgba(82, 64, 38, 0.10);
      transform: rotate(0deg) translateY(-1px);
    }

    html.dark .friend-card:hover img.friend-card__avatar {
      box-shadow: 3px 5px 0 rgba(0, 0, 0, 0.22);
    }

    .friend-card__body {
      min-width: 0;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 2px;
      padding-top: 8px;
    }

    .friend-card__name {
      font-size: 15px;
      font-weight: 700;
      line-height: 1.4;
      color: var(--friends-ink);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .friend-card:hover .friend-card__name {
      color: var(--friends-accent);
    }

    .friend-card__host {
      font-size: 11px;
      color: var(--friends-muted);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .friend-card__desc {
      margin-top: 3px;
      color: var(--friends-muted);
      font-size: 12px;
      line-height: 1.55;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .friend-card__rss {
      flex-shrink: 0;
      display: inline-grid;
      place-items: center;
      width: 28px;
      height: 28px;
      margin-top: 6px;
      border-radius: 50%;
      color: var(--friends-muted);
      background: transparent;
      transition: color 0.25s ease, background 0.25s ease, transform 0.25s ease;
    }

    .friend-card__rss::before {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: 50%;
      border: 1.5px solid currentColor;
      opacity: 0;
      pointer-events: none;
    }

    .friend-card:hover .friend-card__rss {
      color: var(--friends-accent);
      background: color-mix(in srgb, var(--friends-accent) 12%, transparent);
    }

    html.dark .friend-card:hover .friend-card__rss {
      color: var(--friends-accent);
      background: color-mix(in srgb, var(--friends-accent) 15%, transparent);
    }

    .friend-card__rss:hover {
      transform: scale(1.12);
    }

    .friend-card__rss .lucide {
      width: 13px;
      height: 13px;
      transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .friend-card:hover .friend-card__rss .lucide {
      animation: fcl-rss-wiggle 0.7s ease;
    }

    @keyframes fcl-rss-wiggle {
      0%   { transform: rotate(0)    scale(1); }
      25%  { transform: rotate(-8deg) scale(1.08); }
      50%  { transform: rotate(6deg)  scale(1.12); }
      75%  { transform: rotate(-3deg) scale(1.06); }
      100% { transform: rotate(0)    scale(1); }
    }

    .friend-card__extra {
      padding: 12px 18px 16px;
    }

    .friend-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 0.8rem;
    }

    .friend-tag {
      border-radius: 999px;
      background: var(--friends-tag-bg);
      padding: 0.25rem 0.6rem;
      font-size: 0.7rem;
      color: var(--friends-muted);
    }

    .friend-meta-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.7rem;
    }

    .friend-meta-box {
      border: 1px dashed var(--friends-card-border);
      border-radius: 8px;
      background: var(--friends-meta-bg);
      padding: 0.6rem 0.8rem;
    }

    .friend-meta-label {
      font-size: 0.65rem;
      color: var(--friends-muted);
      margin-bottom: 0.2rem;
    }

    .friend-meta-value {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--friends-ink);
    }

    @media (max-width: 640px) {
      .friends-grid {
        grid-template-columns: 1fr;
        gap: 18px;
      }

      .friend-card {
        transform: none;
      }

      .friend-card:hover {
        transform: translateY(-2px);
      }

      .friend-card::before {
        left: 16px;
      }

      .friend-card::after {
        top: 18px;
        right: -5px;
        width: 5px;
        height: 38px;
      }

      .friend-card:hover::after {
        right: -9px;
        width: 9px;
      }

      .friend-shot {
        height: 8rem;
      }

      .friend-card__main {
        padding: 12px 14px 0;
        gap: 10px;
      }

      .friend-card__link {
        gap: 10px;
      }

      img.friend-card__avatar {
        width: 48px;
        height: 48px;
        border-radius: 7px;
      }

      .friend-card__extra {
        padding: 10px 14px 14px;
      }

      .friend-card__rss {
        margin-top: 4px;
      }
    }

    @media (min-width: 641px) and (max-width: 1024px) {
      .friends-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
  </style>
</Layout>
