---
import friendsData from "../../data/friends.json";
import Layout from "../../layouts/Layout.astro";

interface FriendItem {
  name: string;
  url: string;
  avatar: string;
  snapshot?: string;
  desc?: string;
  feed?: string;
  tags?: string;
  links?: string;
}

interface RemoteLinkItem {
  name?: string;
  link?: string;
  link_page?: string;
  latency?: number;
  reachable?: boolean;
}

interface RemoteLinkPayload {
  link_data?: RemoteLinkItem[];
}

const pageTitle = "友链详情 | 喵洛阁";
const pageDescription = "友情链接详细页面";

const formatUrl = (value?: string) => value?.trim().replace(/^`|`$/g, "") ?? "";
const normalizeTagList = (value?: string) =>
  (value ?? "")
    .split(",")
    .map((item) => item.trim())
    .filter(Boolean);

const getHost = (value: string) => {
  try {
    return new URL(value).host.replace(/^www\./, "");
  } catch {
    return value;
  }
};

const formatLatency = (latency?: number) => {
  if (!latency || Number.isNaN(latency)) return "检测中";
  return latency < 1
    ? `${Math.round(latency * 1000)} MS`
    : `${latency.toFixed(1)} S`;
};

const getLatencyTone = (latency?: number, reachable?: boolean) => {
  if (reachable === false) return "down";
  if (!latency || Number.isNaN(latency)) return "idle";
  if (latency < 0.8) return "fast";
  if (latency < 1.8) return "ok";
  return "slow";
};

let latencyMap = new Map<string, { latency?: number; reachable?: boolean }>();

try {
  const response = await fetch("https://fc.2005815.xyz/link.json");
  const remoteData = (await response.json()) as RemoteLinkPayload;
  latencyMap = new Map(
    (remoteData.link_data ?? []).flatMap((item) => {
      const entries: [string, { latency?: number; reachable?: boolean }][] = [];
      const payload = { latency: item.latency, reachable: item.reachable };
      if (item.link) entries.push([formatUrl(item.link), payload]);
      if (item.link_page) entries.push([formatUrl(item.link_page), payload]);
      return entries;
    }),
  );
} catch {
  latencyMap = new Map();
}

const friends = (friendsData as FriendItem[]).map((friend) => {
  const siteUrl = formatUrl(friend.url);
  const linksUrl = formatUrl(friend.links);
  const latencyInfo = latencyMap.get(siteUrl) ?? latencyMap.get(linksUrl);

  return {
    ...friend,
    url: siteUrl,
    links: linksUrl,
    snapshot: formatUrl(friend.snapshot),
    feed: formatUrl(friend.feed),
    desc: friend.desc?.trim() ?? "",
    tags: normalizeTagList(friend.tags),
    host: getHost(siteUrl),
    latency: latencyInfo?.latency,
    reachable: latencyInfo?.reachable,
    latencyText: formatLatency(latencyInfo?.latency),
    latencyTone: getLatencyTone(latencyInfo?.latency, latencyInfo?.reachable),
  };
});
---

<Layout
  title={pageTitle}
  description={pageDescription}
  className="max-w-[1100px] px-4 py-6"
>
  <main class="friends-detail space-y-8">
    <header class="space-y-4">
      <div class="flex items-start justify-between gap-4">
        <div class="space-y-2">
          <nav
            aria-label="Breadcrumb"
            class="text-sm text-zinc-500 dark:text-zinc-400"
          >
            <a href="/" class="hover:underline">喵洛阁</a>
            <span class="mx-1">/</span>
            <a href="/friends/" class="hover:underline">朋友们</a>
            <span class="mx-1">/</span>
          </nav>
          <h1 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-100">
            友链详情
          </h1>
          <p
            class="max-w-2xl text-sm leading-6 text-zinc-600 dark:text-zinc-400"
          >
            保留简洁页作为入口，这里补充站点截图、订阅地址、标签和最近一次延迟检测结果。
          </p>
        </div>
        <div class="flex shrink-0 gap-2">
          <a
            href="/friends/fcircle/"
            class="inline-flex items-center rounded-full border border-zinc-200 bg-white px-3 py-1.5 text-sm text-zinc-600 transition hover:border-zinc-400 hover:text-zinc-900 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-300 dark:hover:border-zinc-700 dark:hover:text-zinc-100"
          >
            朋友圈
          </a>
          <a
            href="/friends/"
            class="inline-flex items-center rounded-full border border-zinc-200 bg-white px-3 py-1.5 text-sm text-zinc-600 transition hover:border-zinc-400 hover:text-zinc-900 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-300 dark:hover:border-zinc-700 dark:hover:text-zinc-100"
          >
            简洁视图
          </a>
        </div>
      </div>
      <div
        class="flex flex-wrap gap-2 text-xs text-zinc-500 dark:text-zinc-400"
      >
        <span
          class="rounded-full border border-zinc-200 px-3 py-1 dark:border-zinc-800"
        >
          共 {friends.length} 位朋友
        </span>
        <span
          class="rounded-full border border-zinc-200 px-3 py-1 dark:border-zinc-800"
        >
          延迟数据源：fc.2005815.xyz
        </span>
      </div>
    </header>

    <section class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
      {
        friends.map((friend) => (
          <article class="friend-card">
            <div class="friend-shot">
              {friend.snapshot ? (
                <img
                  src={friend.snapshot}
                  alt=""
                  class="friend-shot-image"
                  loading="lazy"
                />
              ) : (
                <div class="friend-shot-fallback" />
              )}
              <div class="friend-shot-mask" />
              <span
                class={`friend-latency friend-latency--${friend.latencyTone}`}
              >
                {friend.latencyText}
              </span>
            </div>

            <div class="friend-content">
              <div class="friend-head">
                <img
                  src={friend.avatar}
                  alt={friend.name}
                  class="friend-avatar"
                  loading="lazy"
                />
                <div class="min-w-0 flex-1">
                  <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0 space-y-1">
                      <h2 class="truncate text-xl font-semibold text-zinc-900 dark:text-zinc-100">
                        {friend.name}
                      </h2>
                      <p class="truncate text-sm text-zinc-500 dark:text-zinc-400">
                        {friend.host}
                      </p>
                    </div>
                    {friend.links && (
                      <a
                        href={friend.links}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="friend-link-btn relative z-20"
                        aria-label={`${friend.name} 的友链页`}
                      >
                        友链页
                      </a>
                    )}
                  </div>
                </div>
              </div>

              <p class="friend-desc">
                {friend.desc || "这个朋友暂时还没有补充简介。"}
              </p>

              {friend.tags.length > 0 && (
                <div class="friend-tags">
                  {friend.tags.map((tag) => (
                    <span class="friend-tag">{tag}</span>
                  ))}
                </div>
              )}

              <div class="friend-meta-grid">
                <a
                  href={friend.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="friend-meta-box friend-meta-box--link"
                >
                  <div class="friend-meta-label">主站</div>
                  <div class="friend-meta-value">{friend.host}</div>
                </a>
                <div class="friend-meta-box">
                  <div class="friend-meta-label">订阅</div>
                  {friend.feed ? (
                    <a
                      href={friend.feed}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="friend-feed-link relative z-20"
                    >
                      Atom / RSS
                    </a>
                  ) : (
                    <div class="friend-meta-value">未提供</div>
                  )}
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </section>
  </main>

  <style is:inline>
    .friends-detail {
      --friends-accent: #ffee6f;
      --friends-accent-soft: rgba(255, 238, 111, 0.22);
      --friends-card-bg: rgba(255, 255, 255, 0.88);
      --friends-card-border: rgba(24, 24, 27, 0.08);
      --friends-card-shadow: 0 18px 40px -28px rgba(15, 23, 42, 0.22);
      --friends-shot-fallback: linear-gradient(
        135deg,
        rgba(255, 238, 111, 0.35),
        rgba(255, 255, 255, 0.92)
      );
      --friends-shot-mask: linear-gradient(
        to top,
        rgba(255, 255, 255, 0.98),
        rgba(255, 255, 255, 0.22) 55%,
        rgba(255, 255, 255, 0.02)
      );
      --friends-tag-bg: rgba(24, 24, 27, 0.04);
      --friends-meta-bg: rgba(24, 24, 27, 0.03);
      --friends-muted: #6b7280;
    }

    :global(html.dark) .friends-detail {
      --friends-accent: #b1d5c8;
      --friends-accent-soft: rgba(177, 213, 200, 0.2);
      --friends-card-bg: rgba(24, 24, 27, 0.84);
      --friends-card-border: rgba(255, 255, 255, 0.08);
      --friends-card-shadow: 0 20px 42px -30px rgba(0, 0, 0, 0.42);
      --friends-shot-fallback: linear-gradient(
        135deg,
        rgba(177, 213, 200, 0.22),
        rgba(24, 24, 27, 0.9)
      );
      --friends-shot-mask: linear-gradient(
        to top,
        rgba(24, 24, 27, 0.98),
        rgba(24, 24, 27, 0.28) 55%,
        rgba(24, 24, 27, 0.04)
      );
      --friends-tag-bg: rgba(255, 255, 255, 0.06);
      --friends-meta-bg: rgba(255, 255, 255, 0.04);
      --friends-muted: #a1a1aa;
    }

    .friend-card {
      position: relative;
      overflow: hidden;
      border: 1px solid var(--friends-card-border);
      border-radius: 1.5rem;
      background: var(--friends-card-bg);
      box-shadow: var(--friends-card-shadow);
      backdrop-filter: blur(10px);
      transition:
        transform 0.25s ease,
        box-shadow 0.25s ease,
        border-color 0.25s ease;
    }

    .friend-card:hover {
      transform: translateY(-4px);
      border-color: color-mix(
        in srgb,
        var(--friends-accent) 35%,
        var(--friends-card-border)
      );
      box-shadow: 0 24px 48px -30px
        color-mix(in srgb, var(--friends-accent) 36%, transparent);
    }

    .friend-meta-box--link {
      display: block;
      text-decoration: none;
      color: inherit;
      transition:
        border-color 0.2s ease,
        background-color 0.2s ease;
    }

    .friend-meta-box--link:hover {
      border-color: color-mix(in srgb, var(--friends-accent) 55%, transparent);
      background: var(--friends-accent-soft);
    }

    .friend-shot {
      position: relative;
      height: 10.5rem;
      overflow: hidden;
      border-bottom: 1px solid var(--friends-card-border);
      background: var(--friends-shot-fallback);
    }

    .friend-shot-image {
      height: 100%;
      width: 100%;
      object-fit: cover;
      transition:
        transform 0.45s ease,
        filter 0.45s ease;
    }

    .friend-card:hover .friend-shot-image {
      transform: scale(1.03);
      filter: saturate(0.96);
    }

    .friend-shot-fallback {
      height: 100%;
      width: 100%;
      background: var(--friends-shot-fallback);
    }

    .friend-shot-mask {
      position: absolute;
      inset: 0;
      background: var(--friends-shot-mask);
    }

    .friend-latency {
      position: absolute;
      top: 0.9rem;
      right: 0.9rem;
      z-index: 2;
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      border: 1px solid transparent;
      padding: 0.35rem 0.7rem;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      backdrop-filter: blur(10px);
    }

    .friend-latency--fast,
    .friend-latency--ok {
      background: color-mix(in srgb, var(--friends-accent) 20%, transparent);
      border-color: color-mix(in srgb, var(--friends-accent) 45%, transparent);
      color: color-mix(in srgb, var(--friends-accent) 20%, #0f172a);
    }

    :global(html.dark) .friend-latency--fast,
    :global(html.dark) .friend-latency--ok {
      color: var(--friends-accent);
    }

    .friend-latency--slow {
      background: rgba(245, 158, 11, 0.14);
      border-color: rgba(245, 158, 11, 0.3);
      color: #b45309;
    }

    .friend-latency--down {
      background: rgba(244, 63, 94, 0.14);
      border-color: rgba(244, 63, 94, 0.3);
      color: #be123c;
    }

    .friend-latency--idle {
      background: rgba(113, 113, 122, 0.12);
      border-color: rgba(113, 113, 122, 0.18);
      color: var(--friends-muted);
    }

    .friend-content {
      position: relative;
      z-index: 2;
      padding: 1.2rem 1.25rem 1.25rem;
    }

    .friend-head {
      display: flex;
      align-items: flex-start;
      gap: 0.95rem;
      margin-top: -2.75rem;
    }

    .friend-avatar {
      height: 4.25rem;
      width: 4.25rem;
      flex: 0 0 auto;
      border-radius: 1.2rem;
      border: 3px solid color-mix(in srgb, var(--friends-card-bg) 90%, white);
      object-fit: cover;
      background: #fff;
      box-shadow: 0 10px 20px -14px rgba(15, 23, 42, 0.45);
    }

    .friend-link-btn {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      border: 1px solid var(--friends-card-border);
      background: transparent;
      padding: 0.38rem 0.8rem;
      font-size: 0.75rem;
      color: inherit;
      transition:
        border-color 0.2s ease,
        color 0.2s ease,
        background-color 0.2s ease;
    }

    .friend-link-btn:hover {
      border-color: color-mix(in srgb, var(--friends-accent) 55%, transparent);
      background: var(--friends-accent-soft);
      color: inherit;
    }

    .friend-desc {
      margin-top: 1rem;
      min-height: 3rem;
      color: var(--friends-muted);
      font-size: 0.94rem;
      line-height: 1.75;
    }

    .friend-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin-top: 1rem;
    }

    .friend-tag {
      border-radius: 999px;
      background: var(--friends-tag-bg);
      padding: 0.32rem 0.7rem;
      font-size: 0.75rem;
      color: var(--friends-muted);
    }

    .friend-meta-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.8rem;
      margin-top: 1.15rem;
    }

    .friend-meta-box {
      border: 1px solid var(--friends-card-border);
      border-radius: 1rem;
      background: var(--friends-meta-bg);
      padding: 0.8rem 0.9rem;
    }

    .friend-meta-label {
      font-size: 0.72rem;
      color: var(--friends-muted);
    }

    .friend-meta-value,
    .friend-feed-link {
      display: block;
      margin-top: 0.35rem;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      font-size: 0.95rem;
      font-weight: 500;
      color: #18181b;
    }

    :global(html.dark) .friend-meta-value,
    :global(html.dark) .friend-feed-link {
      color: #f4f4f5;
    }

    .friend-feed-link {
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 0.18em;
      color: inherit;
    }

    .friend-feed-link:hover {
      color: color-mix(in srgb, var(--friends-accent) 30%, #18181b);
    }

    :global(html.dark) .friend-feed-link:hover {
      color: var(--friends-accent);
    }

    @media (max-width: 640px) {
      .friend-content {
        padding: 1rem 1rem 1.05rem;
      }

      .friend-head {
        gap: 0.8rem;
      }

      .friend-avatar {
        height: 3.8rem;
        width: 3.8rem;
      }
    }
  </style>
</Layout>
