---
import { getEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const pageTitle = "友情链接 | Frederick's Blog";
const pageDescription = "我的朋友们";

// Load Markdown content from src/content/friends/index.md
const entry = await getEntry("friends", "index");
if (!entry) {
  throw new Error("Missing content entry: friends/index.md");
}
const { Content } = await entry.render();
---

<Layout
  title={pageTitle}
  description={pageDescription}
  className="max-w-100px flex flex-col justify-center"
>
  <main>
    <header class="mb-6 space-y-2">
      <nav aria-label="Breadcrumb" class="text-sm text-zinc-500">
        <a href="/" class="hover:underline">Frederick's Blog</a>
        <span class="mx-1">/</span>
        <a href="/friends/" class="hover:underline">朋友们</a>
        <span class="mx-1">/</span>
      </nav>
      <h1 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-100">
        交换友链
      </h1>
      <hr class="dark:border-zinc-700" />
    </header>
    <article class="prose dark:prose-invert">
      <Content />
    </article>
  </main>
</Layout>
